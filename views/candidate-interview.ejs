<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Interview - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
body { font-family: 'DM Sans', sans-serif; background: #f8f4ed; margin: 0; }
nav { background: #122040; color: white; padding: 15px; display: flex; justify-content: space-between; }
.logo { font-size: 22px; font-weight: bold; }
.nav-links span { margin: 0 10px; cursor: pointer; }
.question { background: white; margin: 20px; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
textarea { width: 100%; height: 100px; padding: 10px; margin: 10px 0; border: 1px solid #cbd5e1; border-radius: 10px; font-family: inherit; }
#codingAnswer { min-height: 220px; font-family: 'Courier New', Courier, monospace; background: #f8fafc; }
.btn { background: #0a1628; color: white; padding: 10px; border: none; cursor: pointer; margin: 5px; }
.voice-btn { background: #28a745; }
.score { color: #0f766e; font-weight: bold; }
.progress { background: #ddd; height: 20px; border-radius: 10px; margin: 10px 0; }
.progress-bar { background: #0a1628; height: 100%; border-radius: 10px; transition: width 0.3s; }
.sample-mcq { background: #ffffff; padding: 18px; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.08); margin: 20px 0; }
.sample-mcq h3 { margin-top: 0; }
.sample-mcq select, .sample-mcq button { min-width: 150px; }
.sample-mcq-list { margin-top: 1rem; }
.sample-mcq-question { margin-bottom: 1rem; }
.sample-mcq-option { display: flex; align-items: center; margin: 0.35rem 0; }
.sample-mcq-option input { margin-right: 0.5rem; }
.reference-box { background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 12px; padding: 16px; margin: 20px 0; }
.reference-box a { color: #3730a3; text-decoration: none; font-weight: 600; }
.reference-box a:hover { text-decoration: underline; }
</style>
</head>
<body>
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'">Dashboard</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'">Admin</span><% } %>
    <form action="/logout" method="POST" style="display:inline;"><button type="submit" style="background:none;border:none;color:white;cursor:pointer;">Logout</button></form>
  </div>
</nav>

<div style="padding:20px;" id="interviewContent">
  <h1>Interview for <%= job_title %></h1>
  <p>Answer the following questions. You can use voice input or type your responses. Your answers will be evaluated by our AI assistant.</p>

  <div class="reference-box">
    <h3>W3Schools Interview Training Reference</h3>
    <p>Use the W3Schools reference to prepare for questions in HTML, CSS, JavaScript, Python, Java, SQL, C, C++, PHP, and more.</p>
    <p><a href="https://www.w3schools.com/" target="_blank">Visit W3Schools</a> for tutorials, examples, and quick references.</p>
  </div>
  <div class="sample-mcq">
    <h3>Sample MCQ practice</h3>
    <p>Select a field and review a few sample multiple-choice questions before your interview.</p>
    <div style="display:flex; flex-wrap:wrap; gap:0.75rem; align-items:center; margin-top:0.75rem;">
      <label for="sampleField" style="font-weight:600; color:#1e293b;">Field:</label>
      <select id="sampleField">
        <option value="DSA" <%= job_category && job_category.toLowerCase().includes('computer science') ? 'selected' : '' %>>DSA</option>
        <option value="Python" <%= job_category && job_category.toLowerCase().includes('python') ? 'selected' : '' %>>Python</option>
        <option value="Java" <%= job_category && job_category.toLowerCase().includes('java') ? 'selected' : '' %>>Java</option>
        <option value="JavaScript" <%= job_category && job_category.toLowerCase().includes('javascript') ? 'selected' : '' %>>JavaScript</option>
        <option value="HTML" <%= job_category && job_category.toLowerCase().includes('html') ? 'selected' : '' %>>HTML</option>
        <option value="CSS" <%= job_category && job_category.toLowerCase().includes('css') ? 'selected' : '' %>>CSS</option>
        <option value="SQL" <%= job_category && job_category.toLowerCase().includes('sql') ? 'selected' : '' %>>SQL</option>
        <option value="C" <%= job_category && job_category.toLowerCase().includes('c') ? 'selected' : '' %>>C</option>
        <option value="C++" <%= job_category && job_category.toLowerCase().includes('c++') ? 'selected' : '' %>>C++</option>
        <option value="PHP" <%= job_category && job_category.toLowerCase().includes('php') ? 'selected' : '' %>>PHP</option>
      </select>
      <button class="btn" type="button" onclick="showSampleMCQs()">Show Sample MCQs</button>
    </div>
    <div id="sampleMCQContainer" class="sample-mcq-list"></div>
  </div>

  <div class="question" id="codingRound">
    <h3>Coding Round</h3>
    <p>Type a simple code example inspired by W3Schools. Create a working HTML page with a button that displays an alert when clicked.</p>
    <textarea id="codingAnswer" placeholder="Type your code here..."></textarea>
    <div style="display:flex; flex-wrap:wrap; gap:0.75rem; align-items:center; margin-top:0.5rem;">
      <button class="btn" type="button" onclick="loadSampleCode()">Load W3Schools Example</button>
      <button class="btn" type="button" onclick="runCode()">Run Code</button>
      <button class="btn" type="button" onclick="submitCodingRound()">Submit Coding Round</button>
    </div>
    <div id="codingResult" class="score" style="margin-top:0.75rem;"></div>
    <div id="codingPreview" style="background:#ffffff; border:1px solid #cbd5e1; padding:18px; border-radius:12px; margin-top:18px;">
      <h4 style="margin-top:0;">Live Preview</h4>
      <iframe id="codePreviewFrame" sandbox="allow-scripts" style="width:100%; min-height:250px; border:1px solid #cbd5e1; border-radius:10px;"></iframe>
    </div>
  </div>

  <div class="progress">
    <div class="progress-bar" id="progressBar" style="width: 0%;"></div>
  </div>

  <% questions.forEach((q, index) => { %>
    <div class="question" id="question<%= index %>">
      <h3>Question <%= index + 1 %>: <%= q.question %></h3>
      <textarea id="answer<%= q.id %>" placeholder="Type or speak your answer..."><%= q.answer || '' %></textarea>
      <button class="btn voice-btn" onclick="startVoice(<%= q.id %>)">🎤 Voice Input</button>
      <button class="btn" onclick="submitAnswer(<%= q.id %>, <%= index %>)">Submit Answer</button>
      <div class="score"><% if (q.score !== null) { %>Score: <%= q.score %>%<% } %></div>
    </div>
  <% }); %>

  <button class="btn" id="completeBtn" onclick="completeInterview()" style="display:none;">Complete Interview</button>
</div>

<script>
let recognition;
let answeredCount = 0;
let codingCompleted = false;
let totalQuestions = <%= questions.length %>;

function updateProgress() {
  const completed = answeredCount + (codingCompleted ? 1 : 0);
  const total = totalQuestions + 1;
  const progress = Math.round((completed / total) * 100);
  document.getElementById('progressBar').style.width = progress + '%';
  if (completed === total) {
    document.getElementById('completeBtn').style.display = 'block';
  }
}

function startVoice(questionId) {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    alert('Voice recognition not supported in this browser.');
    return;
  }

  recognition = new SpeechRecognition();
  recognition.continuous = false;
  recognition.interimResults = false;
  recognition.lang = 'en-US';

  recognition.onresult = function(event) {
    const transcript = event.results[0][0].transcript;
    document.getElementById('answer' + questionId).value = transcript;
  };

  recognition.start();
}

function submitAnswer(questionId, questionIndex) {
  const answer = document.getElementById('answer' + questionId).value;
  if (!answer.trim()) {
    alert('Please provide an answer.');
    return;
  }

  fetch('/candidate-interview/<%= interviewId %>/answer', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ questionId, answer })
  })
  .then(res => res.json())
  .then(data => {
    alert('Answer submitted. Score: ' + data.score + '%');
    document.querySelector('#question' + questionIndex + ' .score').innerHTML = 'Score: ' + data.score + '%';
    answeredCount++;
    updateProgress();
    document.getElementById('question' + questionIndex).style.opacity = '0.5';

    if (data.followUp) {
      totalQuestions++;
      addFollowUpQuestion(data.followUp, totalQuestions);
    }
  });
}

function submitCodingRound() {
  const code = document.getElementById('codingAnswer').value;
  if (!code.trim()) {
    alert('Please type your coding answer before submitting.');
    return;
  }

  const score = gradeCodingAnswer(code);
  codingCompleted = true;
  document.getElementById('codingResult').innerText = `Coding round submitted. Score: ${score}%`;
  document.getElementById('codingAnswer').style.borderColor = '#0f766e';
  updateProgress();
}

function gradeCodingAnswer(code) {
  let score = 0;
  const lowerCode = code.toLowerCase();
  if (lowerCode.includes('<button')) score += 25;
  if (lowerCode.includes('onclick')) score += 25;
  if (lowerCode.includes('alert(') || lowerCode.includes('window.alert(')) score += 25;
  if (lowerCode.includes('<script') || lowerCode.includes('function')) score += 25;
  if (code.trim().length > 150) score += 10;
  return Math.min(score, 100);
}

function runCode() {
  const code = document.getElementById('codingAnswer').value;
  if (!code.trim()) {
    alert('Please write some code first to preview.');
    return;
  }

  const iframe = document.getElementById('codePreviewFrame');
  iframe.srcdoc = code.includes('<html') ? code : `<html><body>${code}</body></html>`;
}

function loadSampleCode() {
  const sample = `<!DOCTYPE html>
<html>
<head>
  <title>W3Schools Button Example</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f9fafb; padding: 20px; }
    .btn-sample { padding: 12px 22px; background: #007bff; color: white; border: none; border-radius: 8px; cursor: pointer; }
  </style>
</head>
<body>
  <h2>W3Schools-style Button Example</h2>
  <button class="btn-sample" onclick="showMessage()">Click me</button>
  <script>
    function showMessage() {
      alert('Hello! This code uses a button event from W3Schools.');
    }
  </script>
</body>
</html>`;
  document.getElementById('codingAnswer').value = sample;
  document.getElementById('codePreviewFrame').srcdoc = sample;
}

function addFollowUpQuestion(followUp, questionIndex) {
  const questionDiv = document.createElement('div');
  questionDiv.className = 'question';
  questionDiv.id = 'question' + questionIndex;
  questionDiv.innerHTML = `
    <h3>Follow-up Question: ${followUp.question}</h3>
    <textarea id="answer${followUp.id}" placeholder="Type or speak your answer..."></textarea>
    <button class="btn voice-btn" onclick="startVoice(${followUp.id})">🎤 Voice Input</button>
    <button class="btn" onclick="submitAnswer(${followUp.id}, ${questionIndex})">Submit Answer</button>
    <div class="score"></div>
  `;
  document.getElementById('interviewContent').appendChild(questionDiv);
}

function showSampleMCQs() {
  const field = document.getElementById('sampleField').value;
  const sampleMCQs = {
    DSA: [
      { question: 'What is the average-case time complexity of quicksort?', choices: ['O(n)', 'O(log n)', 'O(n log n)', 'O(n^2)'], answer: 2 },
      { question: 'Which data structure is best for implementing a LIFO order?', choices: ['Queue', 'Stack', 'Heap', 'Graph'], answer: 1 }
    ],
    Python: [
      { question: 'Which keyword is used to define a function in Python?', choices: ['func', 'define', 'def', 'function'], answer: 2 },
      { question: 'Which data type is immutable in Python?', choices: ['List', 'Dictionary', 'Tuple', 'Set'], answer: 2 }
    ],
    Java: [
      { question: 'Which of these is a valid Java access modifier?', choices: ['public', 'protected', 'private', 'All of the above'], answer: 3 },
      { question: 'Which keyword is used to inherit a class in Java?', choices: ['extends', 'implements', 'inherits', 'uses'], answer: 0 }
    ]
  };

  const container = document.getElementById('sampleMCQContainer');
  container.innerHTML = '';
  const selectedQuestions = sampleMCQs[field] || sampleMCQs.DSA;

  selectedQuestions.forEach((item, index) => {
    const questionEl = document.createElement('div');
    questionEl.className = 'sample-mcq-question';
    questionEl.innerHTML = `<strong>Q${index + 1}.</strong> ${item.question}`;
    item.choices.forEach((choice, idx) => {
      const label = document.createElement('label');
      label.className = 'sample-mcq-option';
      label.innerHTML = `<input type="radio" name="mcq${index}" value="${idx}"> ${choice}`;
      questionEl.appendChild(label);
    });
    container.appendChild(questionEl);
  });

  const gradeBtn = document.createElement('button');
  gradeBtn.className = 'btn';
  gradeBtn.type = 'button';
  gradeBtn.textContent = 'Check Answers';
  gradeBtn.onclick = () => {
    let score = 0;
    selectedQuestions.forEach((item, index) => {
      const selected = document.querySelector(`input[name="mcq${index}"]:checked`);
      if (selected && parseInt(selected.value, 10) === item.answer) score += 1;
    });
    alert(`Your sample MCQ score for ${field}: ${score} / ${selectedQuestions.length}`);
  };
  container.appendChild(gradeBtn);
}

function completeInterview() {
  fetch('/candidate-interview/<%= interviewId %>/complete', { method: 'POST' })
  .then(() => {
    alert('Interview completed! Check your profile for results.');
    window.location.href = '/profile';
  });
}

// Initialize progress
updateProgress();
</script>
</body>
</html>