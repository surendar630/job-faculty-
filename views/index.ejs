<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AcademiaPro — Faculty & Professor Job Portal</title>

<!-- GOOGLE FONTS -->
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
body{
  font-family:'DM Sans',sans-serif;
  background:#f8f4ed;
  margin:0;
}

/* NAVBAR */
nav{
  background:#122040;
  color:white;
  padding:15px;
  display:flex;
  justify-content:space-between;
}

.logo{
  font-size:22px;
  font-weight:bold;
}

.nav-links span{
  margin:0 10px;
  cursor:pointer;
}

/* HERO */
.hero{
  background:#0a1628;
  color:white;
  text-align:center;
  padding:60px;
}

.hero h1{
  font-size:40px;
}

/* SEARCH */
.search-box{
  background:white;
  padding:15px;
  margin:20px auto;
  max-width:600px;
  border-radius:10px;
  display:flex;
  gap:10px;
}

.search-box input{
  flex:1;
  padding:10px;
}

.search-box button{
  background:#0a1628;
  color:white;
  padding:10px 20px;
  border:none;
  cursor:pointer;
}

/* JOB CARD */
.job-card{
  background:white;
  margin:20px;
  padding:20px;
  border-radius:10px;
  box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

.btn{
  background:#0a1628;
  color:white;
  padding:8px 15px;
  border:none;
  cursor:pointer;
}

</style>
</head>

<body>

<!-- NAV -->
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/'">Home</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <span onclick="window.location.href='/login'">Login</span>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <h1>Find Your Academic Job</h1>
  <p>Top universities hiring worldwide</p>

  <div class="search-box">
    <input type="text" placeholder="Search jobs...">
    <button onclick="alert('Searching...')">Search</button>
  </div>
</div>

<!-- FEATURED JOBS -->
<div style="padding:20px;">
  <h2>Featured Jobs</h2>
  <div id="jobs">
    <% jobs.forEach(j => { %>
      <div class="job-card">
        <h3><%= j.title %></h3>
        <p><%= j.university %> - <%= j.location %></p>
        <p><b><%= j.salary %></b></p>
        <button class="btn" onclick="window.location.href='/login'">View Details</button>
      </div>
    <% }); %>
  </div>
</div>

</body>
</html>