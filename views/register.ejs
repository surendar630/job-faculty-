<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Register - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="/styles.css" rel="stylesheet">
<style>
.register-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1a2332 50%, #8b5cf6 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  position: relative;
  overflow: hidden;
}

.register-hero::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.15), transparent);
  border-radius: 50%;
  pointer-events: none;
}

.register-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  max-width: 1200px;
  width: 100%;
  position: relative;
  z-index: 1;
}

.register-info {
  color: white;
}

.register-info h1 {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  color: white;
}

.register-info p {
  color: rgba(255,255,255,0.9);
  font-size: 1.1rem;
  margin-bottom: 2rem;
}

.form {
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  box-shadow: var(--shadow-xl);
  border-top: 4px solid #8b5cf6;
}

.form h2 {
  text-align: center;
  margin-bottom: 1.5rem;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 0.5rem;
  color: #1e293b;
}

.form-group input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  font-family: inherit;
  font-size: 0.95rem;
  transition: var(--transition);
}

.form-group input:focus {
  outline: none;
  border-color: #8b5cf6;
  box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.1);
}

.form-group button {
  width: 100%;
  padding: 0.75rem;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-size: 1rem;
  box-shadow: var(--shadow-md);
}

.form-group button:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.form p {
  text-align: center;
  margin-top: 1.5rem;
  color: #64748b;
}

.form a {
  color: #6366f1;
  font-weight: 600;
}

@media (max-width: 768px) {
  .register-content {
    grid-template-columns: 1fr;
  }
  
  .register-info {
    display: none;
  }
  
  .form {
    max-width: 100%;
    width: 100%;
  }
}
</style>
</head>
<body>
<div class="register-hero">
  <div class="register-content">
    <div class="register-info">
      <h1>Join AcademiaPro</h1>
      <p>Start your journey to find the perfect academic position or manage your university's hiring process.</p>
    </div>
    
    <div class="form">
      <h2><i class="fas fa-user-plus"></i> Create Account</h2>
      <form action="/register" method="POST">
        <div class="form-group">
          <label for="name"><i class="fas fa-user"></i> Full Name</label>
          <input type="text" id="name" name="name" placeholder="John Doe" required>
        </div>
        <div class="form-group">
          <label for="email"><i class="fas fa-envelope"></i> Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required>
        </div>
        <div class="form-group">
          <label for="password"><i class="fas fa-lock"></i> Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
        <div class="form-group">
          <button type="submit"><i class="fas fa-arrow-right"></i> Create Account</button>
        </div>
      </form>
      <p>Already have an account? <a href="/login"><i class="fas fa-sign-in-alt"></i> Login here</a></p>
    </div>
  </div>
</div>
</body>
</html>