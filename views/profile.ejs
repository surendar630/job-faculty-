<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Profile - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
body { font-family: 'DM Sans', sans-serif; background: #f8f4ed; margin: 0; }
nav { background: #122040; color: white; padding: 15px; display: flex; justify-content: space-between; }
.logo { font-size: 22px; font-weight: bold; }
.nav-links span { margin: 0 10px; cursor: pointer; }
.profile { background: white; margin: 20px; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
</style>
</head>
<body>
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'">Dashboard</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'">Admin</span><% } %>
    <form action="/logout" method="POST" style="display:inline;"><button type="submit" style="background:none;border:none;color:white;cursor:pointer;">Logout</button></form>
  </div>
</nav>
<div class="profile">
  <h1>Your Profile</h1>
  <p><strong>Name:</strong> <%= user.name %></p>
  <p><strong>Email:</strong> <%= user.email %></p>
  <p><strong>Role:</strong> <%= user.role %></p>

  <h2>Your Applications</h2>
  <% if (applications.length === 0) { %>
    <p>No applications yet.</p>
  <% } else { %>
    <% applications.forEach(app => { %>
      <div style="border: 1px solid #ccc; padding: 10px; margin: 10px 0;">
        <h3><%= app.title %></h3>
        <p><%= app.university %> - <%= app.location %></p>
        <p>Status: <%= app.status %></p>
        <p>Applied: <%= new Date(app.applied_at).toLocaleDateString() %></p>        <% if (app.interview_score !== null) { %>
          <p>Interview Score: <%= app.interview_score %>%</p>
        <% } %>      </div>
    <% }); %>
  <% } %>
</div>
</body>
</html>