<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jobs - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
body { font-family: 'DM Sans', sans-serif; background: #f8f4ed; margin: 0; }
nav { background: #122040; color: white; padding: 15px; display: flex; justify-content: space-between; }
.logo { font-size: 22px; font-weight: bold; }
.nav-links span { margin: 0 10px; cursor: pointer; }
.filters { background: white; padding: 20px; margin: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
.job-card { background: white; margin: 20px; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); display: flex; align-items: center; }
.job-info { flex: 1; }
.btn { background: #0a1628; color: white; padding: 8px 15px; border: none; cursor: pointer; margin: 5px; }
.compare-btn { background: #28a745; }
</style>
</head>
<body>
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'">Dashboard</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'">Admin</span><% } %>
    <form action="/logout" method="POST" style="display:inline;"><button type="submit" style="background:none;border:none;color:white;cursor:pointer;">Logout</button></form>
  </div>
</nav>

<div class="filters">
  <form action="/jobs" method="GET">
    <input type="text" name="search" placeholder="Search jobs..." value="<%= search || '' %>">
    <select name="category">
      <option value="">All Categories</option>
      <option value="Computer Science" <%= category === 'Computer Science' ? 'selected' : '' %>>Computer Science</option>
      <option value="Data Science" <%= category === 'Data Science' ? 'selected' : '' %>>Data Science</option>
      <option value="Machine Learning" <%= category === 'Machine Learning' ? 'selected' : '' %>>Machine Learning</option>
      <option value="Engineering" <%= category === 'Engineering' ? 'selected' : '' %>>Engineering</option>
      <option value="Mathematics" <%= category === 'Mathematics' ? 'selected' : '' %>>Mathematics</option>
      <option value="Cybersecurity" <%= category === 'Cybersecurity' ? 'selected' : '' %>>Cybersecurity</option>
    </select>
    <input type="text" name="location" placeholder="Location" value="<%= location || '' %>">
    <select name="sort">
      <option value="">Sort by</option>
      <option value="salary" <%= sort === 'salary' ? 'selected' : '' %>>Salary</option>
    </select>
    <button type="submit" class="btn">Filter</button>
  </form>
</div>

<form action="/compare" method="POST" id="compareForm">
  <div style="padding:20px;">
    <h1>Available Jobs</h1>
    <button type="submit" class="btn compare-btn">Compare Selected</button>
    <% jobs.forEach(job => { %>
      <div class="job-card">
        <input type="checkbox" name="jobIds" value="<%= job.id %>" style="margin-right: 10px;">
        <div class="job-info">
          <h3><%= job.title %></h3>
          <p><%= job.university %> - <%= job.location %> | <%= job.category %></p>
          <p><b><%= job.salary %></b></p>
        </div>
        <button class="btn" onclick="window.location.href='/job/<%= job.id %>'">View Details</button>
      </div>
    <% }); %>
  </div>
</form>

<script>
document.getElementById('compareForm').addEventListener('submit', function(e) {
  const checkboxes = document.querySelectorAll('input[name="jobIds"]:checked');
  if (checkboxes.length < 2) {
    e.preventDefault();
    alert('Please select at least 2 jobs to compare.');
  }
});
</script>
</body>
</html>