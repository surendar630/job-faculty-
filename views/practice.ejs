<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI MCQ Practice - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
body { font-family: 'DM Sans', sans-serif; background: #f8f4ed; margin: 0; }
nav { background: #122040; color: white; padding: 15px; display: flex; justify-content: space-between; align-items: center; }
.logo { font-size: 22px; font-weight: bold; }
.nav-links span, .nav-links a { margin: 0 10px; cursor: pointer; color: white; text-decoration: none; }
.content { padding: 24px; max-width: 1000px; margin: 0 auto; }
.card { background: white; border-radius: 18px; padding: 24px; margin-bottom: 20px; box-shadow: 0 12px 24px rgba(17, 24, 39, 0.08); }
.card h1, .card h2 { margin-top: 0; }
.reference-box { background: #eef2ff; border: 1px solid #c7d2fe; border-radius: 14px; padding: 18px; margin-bottom: 20px; }
.reference-box a { color: #3730a3; text-decoration: none; font-weight: 600; }
.reference-box a:hover { text-decoration: underline; }
.sample-mcq { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; margin-bottom: 1rem; }
.sample-mcq select, .sample-mcq button { padding: 0.9rem 1.2rem; border-radius: 10px; border: 1px solid #cbd5e1; background: #ffffff; color: #0f172a; cursor: pointer; }
.sample-mcq-list { margin-top: 1.5rem; }
.sample-mcq-question { background: #f8fafc; padding: 18px; border-radius: 14px; margin-bottom: 1rem; }
.sample-mcq-option { display: flex; align-items: center; margin-top: 0.65rem; }
.sample-mcq-option input { margin-right: 0.65rem; }
.action-bar { display: flex; gap: 1rem; flex-wrap: wrap; }
.coding-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
#practiceCodingAnswer { width: 100%; min-height: 220px; padding: 14px; border-radius: 14px; border: 1px solid #cbd5e1; font-family: 'Courier New', Courier, monospace; background: #f8fafc; margin-bottom: 1rem; }
.coding-preview { background: #ffffff; padding: 18px; border-radius: 14px; border: 1px solid #cbd5e1; box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08); }
.coding-preview h3 { margin-top: 0; }
.coding-result { color: #0f766e; font-weight: 600; margin-bottom: 1rem; }
.tabs { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.tab { flex: 1; padding: 1rem 1.25rem; border-radius: 14px; border: 1px solid #e2e8f0; background: #edf2ff; color: #1e293b; font-weight: 700; cursor: pointer; text-align: center; }
.tab.active { background: #0f172a; color: white; border-color: #0f172a; }
.tag-list { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1.5rem; }
.tag { padding: 0.8rem 1rem; border-radius: 999px; background: #f1f5f9; border: 1px solid #e2e8f0; color: #0f172a; cursor: pointer; transition: all 0.2s ease; }
.tag.active { background: #6366f1; color: white; border-color: #6366f1; }
.task-card { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 18px; padding: 20px; margin-bottom: 1.5rem; }
.task-label { font-size: 0.9rem; font-weight: 700; color: #6366f1; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; }
.task-description { color: #334155; font-size: 1rem; line-height: 1.6; }
.practice-card { padding: 28px; }
.practice-section { display: block; }
.practice-section.hidden { display: none; }
.section-heading { margin-bottom: 1rem; }
.section-heading h2 { margin: 0; }
.section-meta { color: #475569; margin-top: 0.35rem; font-size: 0.95rem; }
.result-summary { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 18px; padding: 20px; color: #334155; }
#practiceCodingAnswer { min-height: 320px; }
.btn { background: #0a1628; color: white; border: none; border-radius: 10px; padding: 0.95rem 1.2rem; cursor: pointer; }
</style>
</head>
<body>
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'">Dashboard</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'">Admin</span><% } %>
    <a href="/logout">Logout</a>
  </div>
</nav>
<div class="content">
  <div class="card practice-header-card">
    <div class="tabs practice-tabs">
      <button id="tab-mcq" class="tab active" type="button" onclick="switchTab('mcq')">
        MCQ round <span id="mcqProgress">0/0</span>
      </button>
      <button id="tab-coding" class="tab" type="button" onclick="switchTab('coding')">Coding round</button>
      <button id="tab-results" class="tab" type="button" onclick="switchTab('results')">Results</button>
    </div>
    <div class="tag-list" id="practiceTagList">
      <button class="tag active" type="button" onclick="setPracticeField('HTML')">HTML</button>
      <button class="tag" type="button" onclick="setPracticeField('JavaScript')">JavaScript</button>
      <button class="tag" type="button" onclick="setPracticeField('CSS')">CSS</button>
      <button class="tag" type="button" onclick="setPracticeField('Python')">Python</button>
      <button class="tag" type="button" onclick="setPracticeField('DSA')">DSA</button>
      <button class="tag" type="button" onclick="setPracticeField('SQL')">SQL</button>
      <button class="tag" type="button" onclick="setPracticeField('Java')">Java</button>
      <button class="tag" type="button" onclick="setPracticeField('C')">C</button>
      <button class="tag" type="button" onclick="setPracticeField('C++')">C++</button>
      <button class="tag" type="button" onclick="setPracticeField('PHP')">PHP</button>
    </div>
    <div class="task-card">
      <div class="task-label">Task</div>
      <div class="task-description" id="taskDescription">Select a field to load the W3Schools-style practice prompt and coding task.</div>
    </div>
  </div>

  <div class="card practice-card">
    <div id="mcqSection" class="practice-section">
      <div class="section-heading">
        <h2>MCQ Practice</h2>
        <div class="section-meta">Answer the MCQs based on W3Schools-style questions.</div>
      </div>
      <div id="sampleMCQContainer" class="sample-mcq-list"></div>
      <div class="coding-actions" style="justify-content:flex-start; margin-top:1rem;">
        <button class="btn" type="button" onclick="(CURRENT_MCQ_SET = SAMPLE_MCQ_DATA, showSampleMCQs())">Load Practice Questions</button>
        <button class="btn" type="button" onclick="loadW3SchoolsSet()">Load W3Schools Questions</button>
        <button class="btn" type="button" onclick="submitMCQResults(currentField)">Submit MCQ Answers</button>
      </div>
    </div>

    <div id="codingSection" class="practice-section hidden">
      <div class="section-heading">
        <h2>Coding Practice</h2>
        <div class="section-meta">Use the editor below to complete the coding task.</div>
      </div>
      <div class="coding-actions">
        <button class="btn" type="button" onclick="loadSampleCode()">Load example</button>
        <button class="btn" type="button" onclick="runPracticeCode()">Run</button>
        <button class="btn" type="button" onclick="submitCodingRound()">Submit</button>
        <button class="btn" type="button" onclick="getAIFeedback()">Get AI feedback</button>
      </div>
      <textarea id="practiceCodingAnswer" placeholder="Type your code here..."></textarea>
      <div id="practiceCodingResult" class="coding-result"></div>
      <div class="coding-preview">
        <h3>Live Preview</h3>
        <iframe id="practiceCodePreview" sandbox="allow-scripts" style="width:100%; min-height:280px; border:1px solid #cbd5e1; border-radius:12px;"></iframe>
      </div>
    </div>

    <div id="resultsSection" class="practice-section hidden">
      <div class="section-heading">
        <h2>Practice Results</h2>
        <div class="section-meta">Review your latest practice session results.</div>
      </div>
      <div id="resultSummary" class="result-summary">
        <p>No practice session completed yet. Complete an MCQ or coding round to see results here.</p>
      </div>
    </div>
  </div>
</div>
<script>
// Global practice data for MCQs and coding prompts
const SAMPLE_MCQ_DATA = {
  DSA: [
    { question: 'What is the average-case time complexity of quicksort?', choices: ['O(n)', 'O(log n)', 'O(n log n)', 'O(n^2)'], answer: 2 },
    { question: 'Which data structure is best for implementing a LIFO order?', choices: ['Queue', 'Stack', 'Heap', 'Graph'], answer: 1 },
    { question: 'What is the main difference between a stack and a queue?', choices: ['Order of insertion', 'Memory usage', 'Underlying structure', 'Capacity'], answer: 0 }
  ],
  Python: [
    { question: 'Which keyword is used to define a function in Python?', choices: ['func', 'define', 'def', 'function'], answer: 2 },
    { question: 'Which data type is immutable in Python?', choices: ['List', 'Dictionary', 'Tuple', 'Set'], answer: 2 },
    { question: 'How do you handle errors in Python?', choices: ['if/else', 'try/except', 'switch/case', 'throw/catch'], answer: 1 }
  ],
  Java: [
    { question: 'Which keyword is used to inherit a class in Java?', choices: ['extends', 'implements', 'inherits', 'uses'], answer: 0 },
    { question: 'Which of these is a valid Java access modifier?', choices: ['public', 'protected', 'private', 'All of the above'], answer: 3 },
    { question: 'What does JVM stand for?', choices: ['Java Visual Machine', 'Java Virtual Machine', 'Just Virtual Machine', 'Java Version Manager'], answer: 1 }
  ],
  JavaScript: [
    { question: 'What is the difference between var and let in JavaScript?', choices: ['Scope only', 'Type only', 'Both scope and hoisting', 'No difference'], answer: 2 },
    { question: 'Which method adds an element to the end of an array?', choices: ['push()', 'pop()', 'shift()', 'unshift()'], answer: 0 },
    { question: 'How do you write a comment in JavaScript?', choices: ['<!-- -->', '//', '/* */', 'Both // and /* */'], answer: 3 }
  ],
  HTML: [
    { question: 'What does HTML stand for?', choices: ['Hyper Text Markup Language', 'Home Tool Markup Language', 'Hyperlinks and Text Markup Language', 'High Text Machine Language'], answer: 0 },
    { question: 'Which HTML tag is used for the largest heading?', choices: ['<head>', '<h6>', '<h1>', '<title>'], answer: 2 },
    { question: 'Which attribute is used to create a hyperlink?', choices: ['src', 'href', 'link', 'ref'], answer: 1 }
  ],
  CSS: [
    { question: 'How do you select an element with class "button" in CSS?', choices: ['#button', '.button', 'button', '*button'], answer: 1 },
    { question: 'Which property controls the text size?', choices: ['font-style', 'font-weight', 'font-size', 'text-size'], answer: 2 },
    { question: 'Which CSS property is used to change the background color?', choices: ['color', 'background-color', 'bgcolor', 'back-color'], answer: 1 }
  ],
  SQL: [
    { question: 'Which SQL statement is used to extract data from a database?', choices: ['GET', 'OPEN', 'SELECT', 'EXTRACT'], answer: 2 },
    { question: 'What does JOIN do in SQL?', choices: ['Updates data', 'Deletes data', 'Combines rows from multiple tables', 'Renames a table'], answer: 2 },
    { question: 'Which clause is used to filter rows?', choices: ['ORDER BY', 'GROUP BY', 'WHERE', 'HAVING'], answer: 2 }
  ],
  C: [
    { question: 'Which header file is required for printf in C?', choices: ['<stdio.h>', '<stdlib.h>', '<string.h>', '<math.h>'], answer: 0 },
    { question: 'How do you declare a pointer to int in C?', choices: ['int p;', 'int *p;', 'pointer int p;', 'int &p;'], answer: 1 },
    { question: 'What is the size of char in C on most systems?', choices: ['1 byte', '2 bytes', '4 bytes', '8 bytes'], answer: 0 }
  ],
  'C++': [
    { question: 'What is the keyword to define a class in C++?', choices: ['struct', 'object', 'class', 'type'], answer: 2 },
    { question: 'Which feature is used for runtime polymorphism?', choices: ['Templates', 'Inheritance', 'Virtual functions', 'Overloading'], answer: 2 },
    { question: 'What is the purpose of a constructor?', choices: ['Free memory', 'Initialize objects', 'Destroy objects', 'Assign variables'], answer: 1 }
  ],
  PHP: [
    { question: 'Which symbol is used to start PHP code?', choices: ['<?php', '<php>', '{php}', '[php]'], answer: 0 },
    { question: 'Which function is used to output text in PHP?', choices: ['print()', 'echo', 'write()', 'display()'], answer: 1 },
    { question: 'How do you create a PHP array?', choices: ['array()', 'list()', '{}', 'new array()'], answer: 0 }
  ]
};

const CODING_PROMPTS = {
  DSA: 'Write a JavaScript function that checks whether a number is prime. Display results in the console.',
  Python: 'Write a Python snippet that calculates the factorial of a number and prints the result.',
  Java: 'Write a Java method that returns true if a string is a palindrome.',
  JavaScript: 'Write a JavaScript function that adds a click handler to a button and shows an alert.',
  HTML: 'Create a simple HTML page with a button that displays an alert when clicked.',
  CSS: 'Create a small HTML/CSS example where a button changes color on hover.',
  SQL: 'Write a SQL query to select all users from a users table where the role is "student".',
  C: 'Write a C program that prints "Hello, world!" to the console.',
  'C++': 'Write a C++ function that swaps two integers using references.',
  PHP: 'Write a PHP script that outputs "Hello, PHP" to the browser.'
};

// W3Schools-inspired sample question bank (paraphrased)
const W3_SAMPLE_MCQ_DATA = {
  HTML: [
    { question: 'Which tag is used to create a hyperlink?', choices: ['<link>', '<a>', '<href>', '<url>'], answer: 1 },
    { question: 'Which tag defines an unordered list?', choices: ['<ol>', '<ul>', '<li>', '<list>'], answer: 1 },
    { question: 'Which attribute provides alternative text for an image?', choices: ['alt', 'title', 'src', 'caption'], answer: 0 }
  ],
  CSS: [
    { question: 'How do you apply a background color to an element?', choices: ['color', 'background', 'background-color', 'bgcolor'], answer: 2 },
    { question: 'Which property changes the font size?', choices: ['text-size', 'font-size', 'size', 'font-style'], answer: 1 },
    { question: 'Which selector targets elements by class?', choices: ['#class', '.class', 'class', '*class'], answer: 1 }
  ],
  JavaScript: [
    { question: 'How do you log a message to the console?', choices: ['console.log()', 'print()', 'echo()', 'log()'], answer: 0 },
    { question: 'Which keyword declares a variable with block scope?', choices: ['var', 'let', 'const', 'block'], answer: 1 },
    { question: 'Which method converts a JSON string to an object?', choices: ['JSON.parse()', 'JSON.stringify()', 'parseJSON()', 'toObject()'], answer: 0 }
  ],
  Python: [
    { question: 'Which keyword starts a function definition?', choices: ['def', 'function', 'fn', 'define'], answer: 0 },
    { question: 'Which structure is used for ordered, mutable collections?', choices: ['tuple', 'list', 'set', 'dict'], answer: 1 },
    { question: 'How do you write a comment in Python?', choices: ['//', '#', '/* */', '<!-- -->'], answer: 1 }
  ]
};

const W3_CODING_PROMPTS = {
  HTML: 'Create a simple HTML page with a button that shows an alert when clicked.',
  CSS: 'Create a small HTML snippet with a button that changes color on hover using CSS.',
  JavaScript: 'Write JavaScript that adds a click handler to a button and logs a message to the console.',
  Python: 'Write a Python function that returns the factorial of a number.'
};

let currentField = 'HTML';
let currentTab = 'mcq';
let CURRENT_MCQ_SET = SAMPLE_MCQ_DATA;
let lastPracticeResult = null;

function setPracticeField(field) {
  currentField = field;
  document.querySelectorAll('.tag').forEach(btn => {
    btn.classList.toggle('active', btn.textContent.trim() === field);
  });
  document.getElementById('taskDescription').innerText = `Current field: ${field}. Load the questions and practice the selected topic. Use W3Schools as a reference.`;
  if (currentTab === 'mcq') {
    showSampleMCQs();
  } else if (currentTab === 'coding') {
    updateCodingPrompt();
  }
}

function switchTab(tab) {
  currentTab = tab;
  document.getElementById('tab-mcq').classList.toggle('active', tab === 'mcq');
  document.getElementById('tab-coding').classList.toggle('active', tab === 'coding');
  document.getElementById('tab-results').classList.toggle('active', tab === 'results');
  document.getElementById('mcqSection').classList.toggle('hidden', tab !== 'mcq');
  document.getElementById('codingSection').classList.toggle('hidden', tab !== 'coding');
  document.getElementById('resultsSection').classList.toggle('hidden', tab !== 'results');
  if (tab === 'mcq') showSampleMCQs();
  if (tab === 'coding') updateCodingPrompt();
  if (tab === 'results') renderResults();
}

function updateCodingPrompt() {
  const prompt = W3_CODING_PROMPTS[currentField] || CODING_PROMPTS[currentField] || 'Write your code for the selected task.';
  document.getElementById('taskDescription').innerText = prompt;
  document.getElementById('codingQuestionText').innerHTML = `<strong>Coding question:</strong> ${prompt}`;
}

function renderResults() {
  const summary = document.getElementById('resultSummary');
  if (!lastPracticeResult) {
    summary.innerHTML = '<p>No practice session completed yet. Complete an MCQ or coding round to see results here.</p>';
    return;
  }
  summary.innerHTML = `
    <div><strong>Type:</strong> ${lastPracticeResult.type}</div>
    <div><strong>Score:</strong> ${lastPracticeResult.score}%</div>
    <div><strong>Completed:</strong> ${lastPracticeResult.completedQuestions} / ${lastPracticeResult.totalQuestions}</div>
    <div style="margin-top:0.75rem;"><strong>Details:</strong> ${lastPracticeResult.details || 'No extra details.'}</div>
  `;
}

function showSampleMCQs() {
  const field = currentField;
  const container = document.getElementById('sampleMCQContainer');
  const promptText = W3_CODING_PROMPTS[field] || CODING_PROMPTS[field] || 'Answer these practice questions.';
  document.getElementById('taskDescription').innerText = `MCQ practice for ${field}. ${promptText}`;
  document.getElementById('codingQuestionText').innerHTML = `<strong>Coding question:</strong> ${promptText}`;
  container.innerHTML = '';
  const selected = (CURRENT_MCQ_SET && CURRENT_MCQ_SET[field]) ? CURRENT_MCQ_SET[field] : (SAMPLE_MCQ_DATA[field] || SAMPLE_MCQ_DATA.DSA);

  selected.forEach((item, index) => {
    const block = document.createElement('div');
    block.className = 'sample-mcq-question';
    block.innerHTML = `<strong>Q${index + 1}.</strong> ${item.question}`;
    item.choices.forEach((choice, idx) => {
      const label = document.createElement('label');
      label.className = 'sample-mcq-option';
      label.innerHTML = `<input type="radio" name="mcq${index}" value="${idx}"> ${choice}`;
      block.appendChild(label);
    });
    const inputs = block.querySelectorAll('input[type="radio"]');
    inputs.forEach(input => {
      input.addEventListener('change', updateMCQProgress);
    });
    container.appendChild(block);
  });

  const gradeBtn = document.createElement('button');
  gradeBtn.className = 'btn';
  gradeBtn.type = 'button';
  gradeBtn.textContent = 'Check Answers';
  gradeBtn.onclick = () => submitMCQResults(field);

  container.appendChild(gradeBtn);
  updateMCQProgress();
}

function updateMCQProgress() {
  const selected = (CURRENT_MCQ_SET && CURRENT_MCQ_SET[currentField]) ? CURRENT_MCQ_SET[currentField] : (SAMPLE_MCQ_DATA[currentField] || SAMPLE_MCQ_DATA.DSA);
  const answered = selected.reduce((count, item, index) => {
    const selectedOption = document.querySelector(`input[name="mcq${index}"]:checked`);
    return count + (selectedOption ? 1 : 0);
  }, 0);
  document.getElementById('mcqProgress').innerText = `${answered}/${selected.length}`;
}

function playVoiceGuide() {
  const message = 'Select a field and review the sample MCQ questions. Then choose the best answer for each question.';
  const speech = new SpeechSynthesisUtterance(message);
  speech.lang = 'en-US';
  window.speechSynthesis.speak(speech);
}

function loadW3SchoolsSet() {
  CURRENT_MCQ_SET = W3_SAMPLE_MCQ_DATA;
  const field = currentField;
  if (W3_CODING_PROMPTS[field]) {
    document.getElementById('codingQuestionText').innerHTML = `<strong>Coding question:</strong> ${W3_CODING_PROMPTS[field]}`;
    document.getElementById('taskDescription').innerText = W3_CODING_PROMPTS[field];
  }
  showSampleMCQs();
}

function getAIFeedback() {
  const code = document.getElementById('practiceCodingAnswer').value.trim();
  if (!code) {
    alert('Please enter code first to get AI feedback.');
    return;
  }
  const feedback = [];
  if (!code.includes('function') && !code.includes('onclick') && !code.includes('<button')) {
    feedback.push('Try using a function or interactive element to make the task more complete.');
  }
  if (code.includes('alert(') || code.includes('console.log(')) {
    feedback.push('Good: you are using output methods.');
  }
  if (feedback.length === 0) {
    feedback.push('Your code looks reasonable for the current task. Consider adding behavioral details or styling for better results.');
  }
  document.getElementById('practiceCodingResult').innerText = feedback.join(' ');
}

function submitMCQResults(field) {
  const selected = (CURRENT_MCQ_SET && CURRENT_MCQ_SET[field]) ? CURRENT_MCQ_SET[field] : (SAMPLE_MCQ_DATA[field] || SAMPLE_MCQ_DATA.DSA);
  let score = 0;
  let answered = 0;
  const mcqAnswers = [];
  selected.forEach((item, index) => {
    const selectedOption = document.querySelector(`input[name="mcq${index}"]:checked`);
    const userVal = selectedOption ? parseInt(selectedOption.value, 10) : null;
    if (selectedOption) answered++;
    if (userVal !== null && userVal === item.answer) score += 1;
    mcqAnswers.push({ index, question_text: item.question, user_answer: userVal });
  });

  const percent = Math.round((score / selected.length) * 100);
  let resultEl = document.getElementById('mcqResult');
  if (!resultEl) {
    resultEl = document.createElement('div');
    resultEl.id = 'mcqResult';
    resultEl.className = 'coding-result';
    document.getElementById('sampleMCQContainer').appendChild(resultEl);
  }

  fetch('/practice/submit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      totalScore: percent,
      averageScore: percent,
      totalQuestions: selected.length,
      completedQuestions: answered,
      sessionType: 'mcq',
      mcqAnswers
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      resultEl.innerText = `MCQ submitted and saved. Score: ${percent}% (${score}/${selected.length})`;
      lastPracticeResult = {
        type: 'MCQ',
        score: percent,
        totalQuestions: selected.length,
        completedQuestions: answered,
        details: `${score}/${selected.length} correct`
      };
      if (currentTab === 'results') renderResults();
    } else {
      resultEl.innerText = 'Unable to save MCQ results. Try again.';
    }
  })
  .catch(() => { resultEl.innerText = 'Unable to save MCQ results. Try again.'; });
}

let recognition;
let isDictating = false;

function startVoiceDictation() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    alert('Voice recognition is not supported in this browser. Use Chrome or Edge.');
    return;
  }

  if (isDictating && recognition) {
    recognition.stop();
    return;
  }

  recognition = new SpeechRecognition();
  recognition.continuous = true;
  recognition.interimResults = false;
  recognition.lang = 'en-US';
  isDictating = true;

  recognition.onresult = function(event) {
    const transcript = event.results[event.results.length - 1][0].transcript;
    const codeArea = document.getElementById('practiceCodingAnswer');
    codeArea.value += transcript + ' ';
  };

  recognition.onerror = function(event) {
    console.error('Speech recognition error:', event.error);
    isDictating = false;
  };

  recognition.onend = function() {
    isDictating = false;
    const btn = document.getElementById('voiceDictationBtn');
    if (btn) btn.innerText = 'Voice Dictation';
  };

  recognition.start();
  const btn = document.getElementById('voiceDictationBtn');
  if (btn) btn.innerText = 'Stop Dictation';
}

function loadSampleCode() {
  const sample = `<!DOCTYPE html>
<html>
<head>
  <title>W3Schools Button Example</title>
  <style>
    body { font-family: Arial, sans-serif; background: #f9fafb; padding: 24px; }
    .btn-sample { padding: 12px 22px; background: #007bff; color: white; border: none; border-radius: 10px; cursor: pointer; }
  </style>
</head>
<body>
  <h3>W3Schools Button Example</h3>
  <button class="btn-sample" onclick="showMessage()">Click me</button>
  <script>
    function showMessage() {
      alert('Hello! This is a W3Schools-style example.');
    }
  </script>
</body>
</html>`;
  document.getElementById('practiceCodingAnswer').value = sample;
  document.getElementById('practiceCodePreview').srcdoc = sample;
}

function runPracticeCode() {
  const code = document.getElementById('practiceCodingAnswer').value;
  if (!code.trim()) {
    alert('Please enter your code to preview it.');
    return;
  }
  document.getElementById('practiceCodePreview').srcdoc = code.includes('<html') ? code : `<html><body>${code}</body></html>`;
}

function submitCodingRound() {
  const code = document.getElementById('practiceCodingAnswer').value;
  if (!code.trim()) {
    alert('Please type your coding answer before submitting.');
    return;
  }

  const score = gradePracticeCode(code);
  fetch('/practice/submit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      totalScore: score,
      averageScore: score,
      totalQuestions: 1,
      completedQuestions: 1,
      sessionType: 'coding',
      codingAnswer: code,
      mcqAnswers: []
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      document.getElementById('practiceCodingResult').innerText = `Coding round submitted and saved. Score: ${score}%`;
      lastPracticeResult = {
        type: 'Coding',
        score,
        totalQuestions: 1,
        completedQuestions: 1,
        details: 'Coding answer saved for review.'
      };
      if (currentTab === 'results') renderResults();
    } else {
      document.getElementById('practiceCodingResult').innerText = 'Unable to save coding score. Please try again.';
    }
  })
  .catch(() => {
    document.getElementById('practiceCodingResult').innerText = 'Unable to save coding score. Please try again.';
  });
}

function gradePracticeCode(code) {
  let score = 0;
  const text = code.toLowerCase();
  if (text.includes('<button')) score += 25;
  if (text.includes('onclick')) score += 25;
  if (text.includes('alert(') || text.includes('window.alert(')) score += 25;
  if (text.includes('<script') || text.includes('function')) score += 25;
  return Math.min(score, 100);
}

window.addEventListener('load', function() {
  setPracticeField(currentField);
  switchTab('mcq');
});
</script>
</body>
</html>
