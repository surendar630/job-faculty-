<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Interview Trainer - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: #f8fafc; color: #111; min-height: 100vh; }
  nav { background: #0f172a; color: white; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; }
  .logo { font-size: 20px; font-weight: 700; }
  .nav-links { display: flex; gap: 18px; align-items: center; }
  .nav-links span, .nav-links a { color: white; cursor: pointer; text-decoration: none; font-size: 14px; }
  .container { max-width: 980px; margin: 0 auto; padding: 24px 20px; }
  h1 { font-size: 28px; margin-bottom: 6px; }
  .subtitle { font-size: 15px; color: #475569; margin-bottom: 18px; }
  .tabs { display: flex; gap: 8px; border-bottom: 1px solid #e2e8f0; margin-bottom: 20px; }
  .tab { padding: 12px 18px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; background: transparent; color: #64748b; border-bottom: 2px solid transparent; transition: all 0.15s ease; }
  .tab.active { color: #111; border-bottom-color: #111; }
  .tab span.badge { margin-left: 8px; display: inline-block; padding: 2px 8px; border-radius: 999px; background: #e2e8f0; color: #475569; font-size: 11px; }
  .pane { display: none; }
  .pane.active { display: block; }
  .field-tabs { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 18px; }
  .ftab { padding: 8px 14px; border-radius: 999px; border: 1px solid #e2e8f0; background: #fff; color: #475569; cursor: pointer; transition: all 0.15s ease; font-size: 13px; }
  .ftab.on { background: #111827; color: white; border-color: #111827; }
  .card { background: white; border: 1px solid #e2e8f0; border-radius: 14px; padding: 20px; margin-bottom: 18px; }
  .dots { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
  .dot { width: 12px; height: 12px; border-radius: 999px; background: #e2e8f0; }
  .dot.cur { background: #64748b; }
  .dot.ok { background: #16a34a; }
  .dot.bad { background: #dc2626; }
  .q-meta { font-size: 12px; color: #94a3b8; margin-bottom: 10px; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
  .q-text { font-size: 16px; line-height: 1.8; color: #111827; margin-bottom: 18px; }
  .opts { display: grid; gap: 10px; }
  .opt { display: flex; align-items: flex-start; gap: 12px; padding: 14px 16px; border: 1px solid #e2e8f0; border-radius: 12px; cursor: pointer; transition: all 0.15s ease; background: white; }
  .opt:hover { border-color: #94a3b8; }
  .opt.sel { border-color: #2563eb; background: #eff6ff; }
  .opt.ok { border-color: #16a34a; background: #dcfce7; }
  .opt.bad { border-color: #dc2626; background: #fee2e2; }
  .okey { width: 26px; height: 26px; min-width: 26px; border-radius: 999px; border: 1px solid #d1d5db; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; color: #6b7280; font-weight: 700; }
  .opt.sel .okey { background: #2563eb; color: white; border-color: #2563eb; }
  .opt.ok .okey { background: #16a34a; color: white; border-color: #16a34a; }
  .opt.bad .okey { background: #dc2626; color: white; border-color: #dc2626; }
  .otext { font-size: 14px; color: #111827; line-height: 1.7; }
  .fb { margin-top: 14px; padding: 12px 14px; border-radius: 12px; line-height: 1.7; font-size: 14px; }
  .fb.ok { background: #ecfdf5; color: #166534; border: 1px solid #bbf7d0; }
  .fb.bad { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
  .tag { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; }
  .tag-HTML { background: #ffedd5; color: #c2410c; }
  .tag-CSS { background: #dbeafe; color: #1d4ed8; }
  .tag-JavaScript { background: #fef3c7; color: #a16207; }
  .tag-Python { background: #dcfce7; color: #15803d; }
  .tag-DSA { background: #f5d0fe; color: #6b21a8; }
  .tag-CS { background: #e0f2fe; color: #0369a1; }
  .nav-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-top: 14px; }
  .btn { padding: 10px 18px; border-radius: 10px; border: 1px solid #d1d5db; background: white; color: #111827; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 0.15s ease; }
  .btn:hover { background: #f8fafc; }
  .btn.pri { background: #111827; color: white; border-color: #111827; }
  .btn.suc { background: #16a34a; color: white; border-color: #16a34a; }
  .sc { margin-left: auto; color: #475569; font-size: 13px; display: inline-flex; align-items: center; gap: 6px; }
  .cq-sel { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 18px; }
  .cqbtn { padding: 10px 14px; border-radius: 999px; border: 1px solid #e2e8f0; background: white; color: #475569; cursor: pointer; font-size: 13px; font-weight: 600; transition: all 0.15s ease; }
  .cqbtn.on { background: #111827; color: white; border-color: #111827; }
  .coding-prompt { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 16px; font-size: 15px; line-height: 1.7; margin-bottom: 14px; }
  textarea.editor { width: 100%; min-height: 250px; border: 2px solid #e2e8f0; border-radius: 14px; padding: 16px; font-family: 'Courier New', Courier, monospace; font-size: 14px; line-height: 1.6; resize: vertical; background: white; color: #111827; }
  textarea.editor:focus { outline: none; border-color: #111827; }
  .prev-label { margin-top: 18px; margin-bottom: 8px; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: #64748b; font-weight: 700; }
  .prev-box { border: 1px solid #e2e8f0; border-radius: 14px; background: white; overflow: hidden; min-height: 110px; }
  iframe#preview { width: 100%; border: none; min-height: 110px; }
  .ai-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 14px; padding: 16px; margin-top: 16px; font-size: 14px; line-height: 1.8; color: #111827; }
  .ai-box .lbl { display: block; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; color: #64748b; margin-bottom: 10px; }
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin-bottom: 18px; }
  .stat { background: white; border: 1px solid #e2e8f0; border-radius: 14px; padding: 16px; text-align: center; }
  .stat .v { font-size: 26px; font-weight: 700; color: #111827; }
  .stat .l { margin-top: 6px; font-size: 12px; color: #64748b; }
  .ld::after { content: ''; animation: ld 1.2s steps(4,end) infinite; }
  @keyframes ld { 0%,20%{content:'.'} 40%{content:'..'} 60%{content:'...'} 80%,100%{content:''} }
  @media (max-width: 780px) { .tabs { flex-wrap: wrap; } .nav-row { flex-direction: column; align-items: stretch; } }
</style>
</head>
<body>
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'">Dashboard</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'">Admin</span><% } %>
    <a href="/logout">Logout</a>
  </div>
</nav>
<div class="container">
  <h1>Interview Trainer</h1>
  <p class="subtitle">Practice MCQ and coding questions across HTML, CSS, JavaScript, Python, DSA &amp; CS.</p>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('mcq')">MCQ round <span class="badge" id="mcq-badge">0/0</span></button>
    <button class="tab" onclick="switchTab('code')">&lt;/&gt; Coding round</button>
    <button class="tab" onclick="switchTab('results')">Results</button>
  </div>

  <div class="pane active" id="pane-mcq">
    <div class="field-tabs" id="field-tabs"></div>
    <div class="dots" id="dots"></div>
    <div class="card" id="mcq-card">
      <div class="q-meta" id="q-meta"></div>
      <div class="q-text" id="q-text"></div>
      <div class="opts" id="opts"></div>
      <div id="fb"></div>
    </div>
    <div class="nav-row">
      <span class="sc">★ <span id="score-txt">0 / 0</span></span>
      <button class="btn" id="btn-prev" onclick="moveQ(-1)" style="display:none">← Prev</button>
      <button class="btn pri" id="btn-next" onclick="moveQ(1)">Next →</button>
      <button class="btn suc" id="btn-done-mcq" style="display:none" onclick="switchTab('code')">Go to coding →</button>
    </div>
  </div>

  <div class="pane" id="pane-code">
    <div class="cq-sel" id="cq-sel"></div>
    <div class="coding-prompt" id="cq-prompt"></div>
    <textarea class="editor" id="editor" placeholder="Type your code here..."></textarea>
    <div class="prev-label">Live preview</div>
    <div class="prev-box"><iframe id="preview" title="Live code preview"></iframe></div>
    <div id="ai-area"></div>
    <div class="nav-row">
      <button class="btn" onclick="loadExample()">Load example</button>
      <button class="btn" onclick="runPreview()">Run</button>
      <button class="btn pri" onclick="submitCode()">Get AI feedback ↗</button>
      <button class="btn suc" id="btn-results" style="display:none" onclick="switchTab('results')">See results →</button>
    </div>
  </div>

  <div class="pane" id="pane-results">
    <div class="stat-grid" id="stat-grid"></div>
    <div class="card" id="result-detail"></div>
    <div class="nav-row">
      <button class="btn pri" onclick="resetAll()">Restart</button>
    </div>
  </div>
</div>

<script>
const FIELDS = ["All","HTML","CSS","JavaScript","Python","DSA","CS"];
const ALL_Q = [
  {f:"HTML",q:"Which HTML tag defines the document's body?",o:["<head>","<body>","<main>","<content>"],a:1,e:"The <body> tag contains all the visible page content — text, images, links, etc."},
  {f:"HTML",q:"What attribute makes an input field required in HTML5?",o:["mandatory","validate","required","must"],a:2,e:"The 'required' attribute on a form input prevents submission if the field is empty."},
  {f:"HTML",q:"Which tag is used to create a hyperlink?",o:["<link>","<href>","<a>","<url>"],a:2,e:"The <a> (anchor) tag creates hyperlinks. The href attribute specifies the destination URL."},
  {f:"CSS",q:"Which CSS property controls the stacking order of overlapping elements?",o:["stack-order","layer","z-index","depth"],a:2,e:"z-index sets the stack order. Higher values sit on top; it only works on positioned elements."},
  {f:"CSS",q:"What does the 'em' unit in CSS refer to?",o:["Pixels relative to screen","Font size of the root element","Font size of the parent element","Viewport width"],a:2,e:"'em' is relative to the font-size of the parent element. 'rem' is relative to the root <html> element."},
  {f:"CSS",q:"Which property is used to make a flex container?",o:["display: block","display: inline","display: flex","float: left"],a:2,e:"Setting display: flex on a container enables Flexbox layout for its direct children."},
  {f:"JavaScript",q:"Which method removes the last element from a JavaScript array?",o:["shift()","remove()","pop()","delete()"],a:2,e:"Array.pop() removes and returns the last element. shift() removes the first element."},
  {f:"JavaScript",q:"What does '===' check in JavaScript?",o:["Value only","Type only","Value and type","Reference equality"],a:2,e:"=== is strict equality — it checks both value AND type. == does type coercion before comparing."},
  {f:"JavaScript",q:"Which method adds an element to the END of an array?",o:["push()","append()","add()","insert()"],a:0,e:"Array.push() appends one or more elements to the end of an array and returns the new length."},
  {f:"Python",q:"Which keyword is used to define a function in Python?",o:["function","fun","define","def"],a:3,e:"Python uses 'def' to define functions: def my_func():"},
  {f:"Python",q:"What is the output of len([1, 2, 3]) in Python?",o:["2","3","4","Error"],a:1,e:"len() returns the number of items in a list. [1,2,3] has 3 elements → output is 3."},
  {f:"Python",q:"Which of these creates a dictionary in Python?",o:["[]","()","{}","<>"],a:2,e:"Curly braces {} create a dictionary in Python. [] is a list, () is a tuple."},
  {f:"DSA",q:"What is the time complexity of binary search?",o:["O(n)","O(log n)","O(n²)","O(1)"],a:1,e:"Binary search halves the search space each step → O(log n) time complexity."},
  {f:"DSA",q:"Which data structure uses LIFO (Last In, First Out) order?",o:["Queue","Array","Stack","Linked List"],a:2,e:"A stack follows LIFO — the last element pushed is the first one popped. Queues use FIFO."},
  {f:"DSA",q:"What is the worst-case time complexity of bubble sort?",o:["O(n)","O(n log n)","O(n²)","O(log n)"],a:2,e:"Bubble sort compares adjacent elements repeatedly. In the worst case it performs O(n²) comparisons."},
  {f:"CS",q:"What does HTTP stand for?",o:["HyperText Transfer Protocol","High Transfer Text Process","HyperText Transport Program","Host Transfer Text Protocol"],a:0,e:"HTTP = HyperText Transfer Protocol — the foundation of data exchange on the web."},
  {f:"CS",q:"Which of the following is NOT an OOP principle?",o:["Encapsulation","Polymorphism","Compilation","Inheritance"],a:2,e:"The four OOP pillars are Encapsulation, Abstraction, Polymorphism, and Inheritance. Compilation is not one of them."},
  {f:"CS",q:"What does RAM stand for?",o:["Read Access Memory","Random Access Memory","Rapid Application Memory","Remote Access Module"],a:1,e:"RAM stands for Random Access Memory — fast, volatile memory the CPU uses to store data it's actively using."},
];
const CODING_Q = [
  {id:0,f:"HTML",label:"Profile card",prompt:"Build a profile card using HTML & CSS. Show an avatar circle with initials, a name, job title, and a skill badge.",ex:`<style>\n.card{font-family:sans-serif;background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:24px;max-width:240px;text-align:center}\n.av{width:60px;height:60px;border-radius:50%;background:#3b82f6;color:#fff;font-size:20px;font-weight:600;display:flex;align-items:center;justify-content:center;margin:0 auto 12px}\nh2{font-size:17px;margin:0 0 4px;color:#111}p{color:#6b7280;font-size:13px;margin:0 0 10px}\n.badge{background:#eff6ff;color:#1d4ed8;font-size:11px;padding:3px 10px;border-radius:20px}\n</style>\n<div class="card"><div class="av">AR</div><h2>Anya Rao</h2><p>Frontend Developer</p><span class="badge">React · CSS</span></div>`},
  {id:1,f:"JavaScript",label:"Counter app",prompt:"Build a counter app using HTML, CSS & JavaScript. Show a number with + and − buttons. The counter should not go below 0.",ex:`<style>\nbody{font-family:sans-serif;display:flex;justify-content:center;padding:40px}\n.c{text-align:center}.num{font-size:56px;font-weight:700;color:#111;margin:8px 0}.btns{display:flex;gap:12px;justify-content:center}button{width:48px;height:48px;border-radius:50%;border:1px solid #d1d5db;background:#f9fafb;font-size:22px;cursor:pointer}button:hover{background:#e5e7eb}\n</style>\n<div class="c"><div class="num" id="n">0</div><div class="btns"><button onclick="update(-1)">−</button><button onclick="update(1)">+</button></div></div>\n<script>let v=0;function update(d){v=Math.max(0,v+d);document.getElementById('n').textContent=v} <\/script>`},
  {id:2,f:"CSS",label:"Flexbox nav",prompt:"Build a responsive nav bar using CSS Flexbox. Logo left, three nav links right. Dark background with hover effects.",ex:`<style>\n*{box-sizing:border-box;margin:0;padding:0}\nnav{background:#1e293b;display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:54px}\n.brand{color:#f8fafc;font-size:17px;font-weight:700}.links{display:flex;gap:4px}.links a{color:#94a3b8;text-decoration:none;font-size:13px;padding:6px 12px;border-radius:6px;transition:background .15s,color .15s}.links a:hover{background:#334155;color:#f8fafc}\n</style>\n<nav><span class="brand">DevCo</span><div class="links"><a href="#">Home</a><a href="#">About</a><a href="#">Contact</a></div></nav>`},
  {id:3,f:"Python",label:"FizzBuzz",prompt:"Write a Python function fizzbuzz(n) that prints numbers 1 to n. Multiples of 3 → 'Fizz', multiples of 5 → 'Buzz', both → 'FizzBuzz'. (Paste your Python code — AI will review it.)",ex:`def fizzbuzz(n):\n    for i in range(1, n + 1):\n        if i % 15 == 0:\n            print("FizzBuzz")\n        elif i % 3 == 0:\n            print("Fizz")\n        elif i % 5 == 0:\n            print("Buzz")\n        else:\n            print(i)\n\nfizzbuzz(20)`},
  {id:4,f:"DSA",label:"Reverse a string",prompt:"Write a function (any language) to reverse a string without using built-in reverse methods. Example: 'hello' → 'olleh'",ex:`function reverseString(str) {\n  let result = '';\n  for (let i = str.length - 1; i >= 0; i--) {\n    result += str[i];\n  }\n  return result;\n}\n\nconsole.log(reverseString('hello')); // 'olleh'`},
];
let curField = "All", curIdx = 0, answered = {}, selCQ = 0, codeRating = "", codeFeedback = "";
function filteredQ() { return curField === "All" ? ALL_Q : ALL_Q.filter(q => q.f === curField); }
function tagEl(field) { return `<span class="tag tag-${field}">${field}</span>`; }
function debounce(fn, ms) { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); }; }
function renderFieldTabs() { const c = document.getElementById("field-tabs"); c.innerHTML = ""; FIELDS.forEach(f => { const b = document.createElement("button"); b.className = "ftab" + (f === curField ? " on" : ""); b.textContent = f; b.onclick = () => { curField = f; curIdx = 0; renderFieldTabs(); renderQ(); }; c.appendChild(b); }); }
function renderDots() { const qs = filteredQ(); const c = document.getElementById("dots"); c.innerHTML = ""; qs.forEach((q, i) => { const key = ALL_Q.indexOf(q); const d = document.createElement("div"); d.className = "dot" + (i === curIdx ? " cur" : answered[key] === true ? " ok" : answered[key] === false ? " bad" : ""); c.appendChild(d); }); }
function renderQ() { const qs = filteredQ(); if (!qs.length) { document.getElementById("mcq-card").innerHTML = '<p style="font-size:14px;color:#64748b;padding:8px 0">No questions in this category.</p>'; renderDots(); return; } if (curIdx >= qs.length) curIdx = qs.length - 1; const q = qs[curIdx]; const key = ALL_Q.indexOf(q); const isAnswered = answered[key] !== undefined; document.getElementById("q-meta").innerHTML = `<span>Question ${curIdx + 1} of ${qs.length}</span>${tagEl(q.f)}`; document.getElementById("q-text").textContent = q.q; const opts = document.getElementById("opts"); opts.innerHTML = ""; ["A","B","C","D"].forEach((k, i) => { const d = document.createElement("div"); let cls = "opt" + (isAnswered ? " locked" : ""); if (isAnswered) { if (i === q.a) cls += " ok"; else if (i === answered[key] && answered[key] !== q.a) cls += " bad"; } d.className = cls; d.innerHTML = `<span class="okey">${k}</span><span class="otext">${q.o[i]}</span>`; if (!isAnswered) d.onclick = () => selectOpt(key, q, i); opts.appendChild(d); }); const fb = document.getElementById("fb"); if (isAnswered) { const correct = answered[key] === q.a; fb.innerHTML = `<div class="fb ${correct ? 'ok' : 'bad'}">${correct ? '&#10003; Correct! ' : '&#10007; Not quite. '}${q.e}</div>`; } else { fb.innerHTML = ""; } document.getElementById("btn-prev").style.display = curIdx === 0 ? "none" : ""; const isLast = curIdx === qs.length - 1; document.getElementById("btn-next").style.display = isLast ? "none" : ""; document.getElementById("btn-done-mcq").style.display = isLast && isAnswered ? "" : "none"; renderDots(); updateBadge(); }
function selectOpt(key, q, i) { answered[key] = i; renderQ(); }
function moveQ(dir) { const qs = filteredQ(); curIdx = Math.max(0, Math.min(qs.length - 1, curIdx + dir)); renderQ(); }
function updateBadge() { const qs = filteredQ(); const done = qs.filter(q => answered[ALL_Q.indexOf(q)] !== undefined).length; const correct = qs.filter(q => answered[ALL_Q.indexOf(q)] === q.a).length; document.getElementById("mcq-badge").textContent = `${correct}/${done}`; document.getElementById("score-txt").textContent = `${correct} / ${done} correct`; }
function renderCodingPane() { const sel = document.getElementById("cq-sel"); sel.innerHTML = ""; CODING_Q.forEach((q, i) => { const b = document.createElement("button"); b.className = "cqbtn" + (i === selCQ ? " on" : ""); b.innerHTML = `${tagEl(q.f)} ${q.label}`; b.onclick = () => { selCQ = i; renderCodingPane(); }; sel.appendChild(b); }); const cq = CODING_Q[selCQ]; document.getElementById("cq-prompt").innerHTML = `<strong>Task:</strong> ${cq.prompt.replace(/\n/g, "<br>")}`; document.getElementById("ai-area").innerHTML = ""; document.getElementById("btn-results").style.display = "none"; }
function loadExample() { document.getElementById("editor").value = CODING_Q[selCQ].ex; runPreview(); }
function runPreview() { const code = document.getElementById("editor").value; const iframe = document.getElementById("preview"); const doc = iframe.contentDocument || iframe.contentWindow.document; doc.open(); doc.write(code); doc.close(); iframe.style.height = "auto"; setTimeout(() => { iframe.style.height = (doc.body.scrollHeight + 20) + "px"; }, 220); }
document.getElementById("editor").addEventListener("input", debounce(runPreview, 700));
async function submitCode() { const code = document.getElementById("editor").value.trim(); if (!code) { alert("Please write some code first!"); return; } runPreview(); const area = document.getElementById("ai-area"); area.innerHTML = `<div class="ai-box"><div class="lbl">AI feedback</div><span class="ld">Reviewing your code</span></div>`; const cq = CODING_Q[selCQ]; try { const res = await fetch("https://api.anthropic.com/v1/messages", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ model: "claude-sonnet-4-20250514", max_tokens: 1000, messages: [{ role: "user", content: `You are a technical interview coach. A candidate submitted this solution:\n\nTask: ${cq.prompt}\n\nCode:\n${code}\n\nGive concise feedback (3-4 sentences): correctness, code quality, and one improvement tip. End with: Rating: Excellent / Good / Needs improvement.` }] }) }); const data = await res.json(); const text = data.content?.map(b => b.text || "").join("") || "Could not get feedback."; codeRating = text.includes("Excellent") ? "Excellent" : text.includes("Good") ? "Good" : "Needs work"; codeFeedback = text; area.innerHTML = `<div class="ai-box"><div class="lbl">AI feedback</div>${text.replace(/\n/g, "<br>")}</div>`; document.getElementById("btn-results").style.display = ""; } catch(e) { area.innerHTML = `<div class="ai-box"><div class="lbl">AI feedback</div>Could not connect to AI. Check your connection and API key.</div>`; } }
function showResults() { const correct = ALL_Q.filter((q, i) => answered[i] === q.a).length; const done = Object.keys(answered).length; const pct = done ? Math.round((correct / done) * 100) : 0; const overall = pct >= 80 && codeRating === "Excellent" ? "Excellent" : pct >= 60 ? "Good" : "Keep going"; document.getElementById("stat-grid").innerHTML = `<div class="stat"><div class="v">${correct}/${ALL_Q.length}</div><div class="l">MCQ correct</div></div><div class="stat"><div class="v">${pct}%</div><div class="l">MCQ accuracy</div></div><div class="stat"><div class="v">${codeRating || "—"}</div><div class="l">Code rating</div></div><div class="stat"><div class="v">${overall}</div><div class="l">Overall</div></div>`; document.getElementById("result-detail").innerHTML = codeFeedback ? `<p style="font-size:14px;color:#475569;line-height:1.7"><strong style="color:#111">Coding feedback:</strong><br>${codeFeedback}</p>` : `<p style="font-size:14px;color:#64748b">Complete the coding round to see full feedback here.</p>`; }
function switchTab(name) { const tabs = document.querySelectorAll(".tab"); tabs.forEach((t, idx) => t.classList.toggle("active", ["mcq","code","results"][idx] === name)); const panes = document.querySelectorAll(".pane"); panes.forEach((p, idx) => p.classList.toggle("active", ["pane-mcq","pane-code","pane-results"][idx] === "pane-" + name)); if (name === "results") showResults(); }
function resetAll() { answered = {}; selCQ = 0; codeRating = ""; codeFeedback = ""; curIdx = 0; curField = "All"; document.getElementById("editor").value = ""; renderFieldTabs(); renderQ(); renderCodingPane(); switchTab("mcq"); }
renderFieldTabs(); renderQ(); renderCodingPane();
</script>
</body>
</html>
