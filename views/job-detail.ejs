<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Job Details - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
body { font-family: 'DM Sans', sans-serif; background: #f8f4ed; margin: 0; }
nav { background: #122040; color: white; padding: 15px; display: flex; justify-content: space-between; }
.logo { font-size: 22px; font-weight: bold; }
.nav-links span { margin: 0 10px; cursor: pointer; }
.job-detail { background: white; margin: 20px; padding: 20px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
.btn { background: #0a1628; color: white; padding: 8px 15px; border: none; cursor: pointer; }
</style>
</head>
<body>
<nav>
  <div class="logo">AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'">Dashboard</span>
    <span onclick="window.location.href='/jobs'">Jobs</span>
    <span onclick="window.location.href='/profile'">Profile</span>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'">Admin</span><% } %>
    <form action="/logout" method="POST" style="display:inline;"><button type="submit" style="background:none;border:none;color:white;cursor:pointer;">Logout</button></form>
  </div>
</nav>
<div class="job-detail">
  <h1><%= job.title %></h1>
  <p><strong>University:</strong> <%= job.university %></p>
  <p><strong>Location:</strong> <%= job.location %></p>
  <p><strong>Salary:</strong> <%= job.salary %></p>
  <p><strong>Category:</strong> <%= job.category %></p>
  <% if (job.description) { %>
    <h3>Job Description</h3>
    <p><%= job.description %></p>
  <% } %>
  <% if (job.requirements) { %>
    <h3>Requirements</h3>
    <p><%= job.requirements %></p>
  <% } %>
  <% if (applied) { %>
    <p style="color: green;">You have already applied for this job.</p>
    <a href="/candidate-interview/<%= job.id %>"><button class="btn">Take Interview</button></a>
  <% } else { %>
    <form action="/apply/<%= job.id %>" method="POST">
      <button class="btn" type="submit">Apply Now</button>
    </form>
  <% } %>
  <br><br>
  <a href="/jobs"><button class="btn" style="background: #17a2b8;">More Vacancies</button></a>
</div>
</body>
</html>