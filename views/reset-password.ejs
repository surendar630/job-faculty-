<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Password - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="/styles.css" rel="stylesheet">
<style>
.login-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1a2332 50%, #6366f1 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  position: relative;
  overflow: hidden;
}
.login-hero::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(139, 92, 246, 0.15), transparent);
  border-radius: 50%;
  pointer-events: none;
}
.login-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  max-width: 1200px;
  width: 100%;
  position: relative;
  z-index: 1;
}
.login-info {
  color: white;
}
.login-info h1 {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  color: white;
}
.login-info p {
  color: rgba(255,255,255,0.9);
  font-size: 1.1rem;
  margin-bottom: 2rem;
  line-height: 1.8;
}
.features {
  list-style: none;
  margin-bottom: 2rem;
}
.features li {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
  color: rgba(255,255,255,0.85);
}
.features i {
  color: #6366f1;
  font-size: 1.3rem;
  min-width: 30px;
}
.form {
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  box-shadow: var(--shadow-xl);
  border-top: 4px solid #6366f1;
}
.form h2 {
  text-align: center;
  margin-bottom: 1.5rem;
  color: #0f172a;
}
.form-group {
  margin-bottom: 1.5rem;
}
.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 0.5rem;
  color: #1e293b;
}
.form-group input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  font-family: inherit;
  font-size: 0.95rem;
  transition: var(--transition);
}
.form-group input:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}
.form-group button {
  width: 100%;
  padding: 0.75rem;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-size: 1rem;
  box-shadow: var(--shadow-md);
}
.form-group button:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}
.alert {
  border-radius: 10px;
  padding: 1rem 1rem;
  margin-bottom: 1.25rem;
  font-size: 0.95rem;
}
.alert-error {
  background: #fee2e2;
  color: #b91c1c;
  border: 1px solid #fecaca;
}
.alert-info {
  background: #e0f2fe;
  color: #0369a1;
  border: 1px solid #bae6fd;
}
.password-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}
.password-row .form-group {
  flex: 1;
}
.password-strength {
  height: 10px;
  border-radius: 8px;
  background: #e2e8f0;
  margin-top: 0.5rem;
  overflow: hidden;
}
.password-strength span {
  display: block;
  height: 100%;
  border-radius: 8px;
  transition: width 0.25s ease;
}
.password-strength span.weak {
  width: 33%;
  background: #f97316;
}
.password-strength span.medium {
  width: 66%;
  background: #fbbf24;
}
.password-strength span.strong {
  width: 100%;
  background: #34d399;
}
.form p {
  text-align: center;
  margin-top: 1.5rem;
  color: #64748b;
}
.form a {
  color: #6366f1;
  font-weight: 600;
  transition: var(--transition);
}
.form a:hover {
  color: #8b5cf6;
}
@media (max-width: 768px) {
  .login-content {
    grid-template-columns: 1fr;
  }
  .login-info {
    display: none;
  }
  .form {
    max-width: 100%;
    width: 100%;
  }
}
</style>
</head>
<body>
<div class="login-hero">
  <div class="login-content">
    <div class="login-info">
      <h1>Secure Password Reset</h1>
      <p>Use the secure link sent to your email and complete the reset with a strong password.</p>
      <ul class="features">
        <li><i class="fas fa-shield-alt"></i> Token-based reset workflow</li>
        <li><i class="fas fa-user-check"></i> Protect your account</li>
        <li><i class="fas fa-lock"></i> Built-in strength validation</li>
      </ul>
    </div>
    <div class="form">
      <h2><i class="fas fa-key"></i> Set a New Password</h2>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (info) { %>
        <div class="alert alert-info"><%= info %></div>
      <% } %>
      <div class="form-group">
        <label>Email</label>
        <input type="text" value="<%= email %>" disabled>
      </div>
      <form action="/reset/<%= token %>" method="POST">
        <input type="hidden" name="email" value="<%= email %>">
        <div class="form-group">
          <label for="password"><i class="fas fa-lock"></i> New Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="new-password">
          <div class="password-strength"><span id="strengthBar" class="weak"></span></div>
          <div id="strengthLabel" style="margin-top: 0.5rem; color:#475569; font-size:0.95rem;">Enter a strong password</div>
        </div>
        <div class="form-group">
          <label for="confirm_password"><i class="fas fa-lock"></i> Confirm Password</label>
          <input type="password" id="confirm_password" name="confirm_password" placeholder="••••••••" required autocomplete="new-password">
        </div>
        <div class="form-group">
          <label style="display: inline-flex; align-items: center; gap: 0.5rem;"><input type="checkbox" id="showPasswordReset"> Show passwords</label>
        </div>
        <div class="form-group">
          <button type="submit"><i class="fas fa-save"></i> Update Password</button>
        </div>
      </form>
      <p>Remembered your password? <a href="/login"><i class="fas fa-arrow-left"></i> Back to login</a></p>
    </div>
  </div>
</div>
<script>
  const passwordInput = document.getElementById('password');
  const confirmInput = document.getElementById('confirm_password');
  const strengthBar = document.getElementById('strengthBar');
  const strengthLabel = document.getElementById('strengthLabel');
  const showPasswordReset = document.getElementById('showPasswordReset');

  function updateStrength() {
    const value = passwordInput.value;
    const score = [/.{8,}/, /[A-Z]/, /[0-9]/, /[^A-Za-z0-9]/].reduce((count, re) => count + (re.test(value) ? 1 : 0), 0);
    if (score <= 1) {
      strengthBar.className = 'weak';
      strengthLabel.textContent = 'Weak password — use 8+ characters, letters and numbers.';
    } else if (score === 2 || score === 3) {
      strengthBar.className = 'medium';
      strengthLabel.textContent = 'Fair password — add symbols for stronger security.';
    } else {
      strengthBar.className = 'strong';
      strengthLabel.textContent = 'Strong password — good to go!';
    }
  }

  passwordInput.addEventListener('input', updateStrength);
  showPasswordReset.addEventListener('change', () => {
    const type = showPasswordReset.checked ? 'text' : 'password';
    passwordInput.type = type;
    confirmInput.type = type;
  });
</script>
</body>
</html>
