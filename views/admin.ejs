<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="/styles.css" rel="stylesheet">
<style>
.admin-header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
  padding: 2rem;
  border-radius: 12px;
  margin-bottom: 2rem;
  box-shadow: var(--shadow-lg);
}

.admin-header h1 {
  color: white;
  margin-top: 0;
}

.admin-grid {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 2rem;
  margin-bottom: 2rem;
}

.form-section {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: var(--shadow-md);
  border-left: 4px solid #6366f1;
}

.form-section h3 {
  margin-top: 0;
  color: #0f172a;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: #1e293b;
}

.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  font-family: inherit;
  font-size: 0.95rem;
  transition: var(--transition);
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

.form-group textarea {
  resize: vertical;
  min-height: 100px;
}

.form-group button {
  width: 100%;
  padding: 0.75rem;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-size: 1rem;
  box-shadow: var(--shadow-md);
}

.form-group button:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.jobs-section, .applications-section {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: var(--shadow-md);
  margin-bottom: 2rem;
  border-left: 4px solid #6366f1;
}

.section-title {
  font-size: 1.5rem;
  font-weight: 600;
  color: #0f172a;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 0;
}

.jobs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.job-item {
  background: white;
  border: 1px solid #e2e8f0;
  padding: 1.5rem;
  border-radius: 8px;
  transition: var(--transition);
}

.job-item:hover {
  box-shadow: var(--shadow-md);
  border-color: #6366f1;
}

.job-item h4 {
  color: #6366f1;
  margin-top: 0;
}

.job-item-info {
  color: #64748b;
  font-size: 0.9rem;
  margin: 0.5rem 0;
}

.job-item-actions {
  display: flex;
  gap: 0.5rem;
  margin-top: 1rem;
}

.job-item-actions .btn {
  flex: 1;
  padding: 0.6rem;
  font-size: 0.85rem;
  margin: 0;
}

.applications-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.application-item {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-left: 4px solid #6366f1;
  padding: 1.5rem;
  border-radius: 8px;
  transition: var(--transition);
}

.application-item:hover {
  background: white;
  box-shadow: var(--shadow-md);
}

.app-item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1rem;
}

.app-item-title {
  font-weight: 600;
  color: #0f172a;
  margin: 0;
}

.app-item-meta {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
  color: #64748b;
  font-size: 0.9rem;
  margin: 0.5rem 0;
}

.app-status {
  display: inline-block;
  padding: 0.4rem 1rem;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 600;
}

.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-shortlisted {
  background: #dbeafe;
  color: #1e40af;
}

.app-item-actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.app-item-actions .btn {
  padding: 0.6rem 1rem;
  font-size: 0.85rem;
  margin: 0;
}

.empty-state {
  text-align: center;
  padding: 2rem;
  color: #64748b;
}

@media (max-width: 768px) {
  .admin-grid {
    grid-template-columns: 1fr;
  }

  .jobs-grid {
    grid-template-columns: 1fr;
  }

  .app-item-header {
    flex-direction: column;
  }
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo"><i class="fas fa-graduation-cap"></i> AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'"><i class="fas fa-home"></i> Dashboard</span>
    <span onclick="window.location.href='/jobs'"><i class="fas fa-briefcase"></i> Jobs</span>
    <span onclick="window.location.href='/profile'"><i class="fas fa-user"></i> Profile</span>
    <span onclick="window.location.href='/admin'"><i class="fas fa-cog"></i> Admin</span>
    <form action="/logout" method="POST" style="display:inline;">
      <button type="submit" style="background:none;border:none;color:#cbd5e1;cursor:pointer;font-weight:500;transition:var(--transition);" onmouseover="this.style.color='#6366f1'" onmouseout="this.style.color='#cbd5e1'"><i class="fas fa-sign-out-alt"></i> Logout</button>
    </form>
  </div>
</nav>

<div class="container">
  <!-- ADMIN HEADER -->
  <div class="admin-header">
    <h1><i class="fas fa-cog"></i> Admin Panel</h1>
    <p>Manage job postings, applications, and candidate interviews</p>
  </div>

  <!-- ADD JOB FORM -->
  <div class="admin-grid">
    <div class="form-section">
      <h3><i class="fas fa-plus-circle"></i> Add New Job</h3>
      <form action="/admin/job" method="POST">
        <div class="form-group">
          <label for="title"><i class="fas fa-briefcase"></i> Job Title</label>
          <input type="text" id="title" name="title" placeholder="e.g., Senior Professor" required>
        </div>
        <div class="form-group">
          <label for="university"><i class="fas fa-school"></i> University</label>
          <input type="text" id="university" name="university" placeholder="e.g., Stanford University" required>
        </div>
        <div class="form-group">
          <label for="location"><i class="fas fa-map-marker-alt"></i> Location</label>
          <input type="text" id="location" name="location" placeholder="e.g., California, USA" required>
        </div>
        <div class="form-group">
          <label for="salary"><i class="fas fa-dollar-sign"></i> Salary</label>
          <input type="text" id="salary" name="salary" placeholder="e.g., $120,000 - $180,000" required>
        </div>
        <div class="form-group">
          <label for="category"><i class="fas fa-tag"></i> Category</label>
          <select id="category" name="category" required>
            <option value="">Select Category</option>
            <option value="Computer Science">Computer Science</option>
            <option value="Data Science">Data Science</option>
            <option value="Machine Learning">Machine Learning</option>
            <option value="Engineering">Engineering</option>
            <option value="Mathematics">Mathematics</option>
            <option value="Cybersecurity">Cybersecurity</option>
            <option value="Software Engineering">Software Engineering</option>
          </select>
        </div>
        <div class="form-group">
          <label for="description"><i class="fas fa-align-left"></i> Job Description</label>
          <textarea id="description" name="description" placeholder="Describe the job responsibilities and requirements..." required></textarea>
        </div>
        <div class="form-group">
          <label for="requirements"><i class="fas fa-list-check"></i> Key Requirements</label>
          <textarea id="requirements" name="requirements" placeholder="List the key requirements for this position..." required></textarea>
        </div>
        <div class="form-group">
          <button type="submit"><i class="fas fa-plus"></i> Add Job</button>
        </div>
      </form>
    </div>

    <!-- JOBS LIST -->
    <div class="jobs-section">
      <h3 class="section-title"><i class="fas fa-list"></i> Existing Jobs</h3>
      <div class="jobs-grid">
        <% if (jobs.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <p>No jobs posted yet. Create your first job posting!</p>
          </div>
        <% } else { jobs.forEach(job => { %>
          <div class="job-item">
            <h4><i class="fas fa-briefcase"></i> <%= job.title %></h4>
            <div class="job-item-info"><i class="fas fa-school"></i> <%= job.university %></div>
            <div class="job-item-info"><i class="fas fa-map-marker-alt"></i> <%= job.location %></div>
            <div class="job-item-info"><i class="fas fa-tag"></i> <%= job.category %></div>
            <div class="job-item-actions">
              <a href="/admin/job/<%= job.id %>/edit" class="btn btn-primary" style="text-decoration: none;">
                <i class="fas fa-edit"></i> Edit
              </a>
              <form action="/admin/job/<%= job.id %>/delete" method="POST" style="flex: 1;">
                <button type="submit" class="btn btn-secondary" style="width: 100%; background: #ef4444; color: white; border: none;">
                  <i class="fas fa-trash"></i> Delete
                </button>
              </form>
            </div>
          </div>
        <% }); } %>
      </div>
    </div>
  </div>

  <!-- APPLICATIONS SECTION -->
  <div class="applications-section">
    <h3 class="section-title"><i class="fas fa-file-alt"></i> Candidate Applications</h3>
    <div class="applications-list">
      <% if (applications.length === 0) { %>
        <div class="empty-state">
          <i class="fas fa-inbox"></i>
          <p>No applications yet. Candidates will appear here once they apply!</p>
        </div>
      <% } else { applications.forEach(app => { %>
        <div class="application-item">
          <div class="app-item-header">
            <div>
              <h4 class="app-item-title"><i class="fas fa-file-alt"></i> <%= app.job_title %></h4>
              <div class="app-item-meta">
                <span><i class="fas fa-user"></i> <%= app.candidate_name %></span>
                <span><i class="fas fa-calendar"></i> <%= new Date(app.applied_at).toLocaleDateString() %></span>
              </div>
            </div>
            <span class="app-status status-<%= app.status.toLowerCase() %>">
              <i class="fas fa-tag"></i> <%= app.status.charAt(0).toUpperCase() + app.status.slice(1) %>
            </span>
          </div>

          <% if (app.interview_score !== null) { %>
            <div style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; padding: 0.75rem; border-radius: 6px; margin-bottom: 1rem; text-align: center;">
              <strong>Interview Score: <%= app.interview_score %>%</strong>
            </div>
          <% } %>

          <div class="app-item-actions">
            <% if (app.status === 'pending') { %>
              <form action="/admin/application/<%= app.id %>/shortlist" method="POST">
                <button type="submit" class="btn btn-primary">
                  <i class="fas fa-check"></i> Shortlist
                </button>
              </form>
              <a href="/interview/<%= app.id %>" class="btn btn-secondary" style="text-decoration: none;">
                <i class="fas fa-microphone"></i> Start Interview
              </a>
            <% } %>
          </div>
        </div>
      <% }); } %>
    </div>
  </div>
</div>

</body>
</html>