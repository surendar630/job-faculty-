<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="/styles.css" rel="stylesheet">
<style>
.welcome-section {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
  padding: 3rem 2rem;
  border-radius: 12px;
  margin-bottom: 3rem;
  box-shadow: var(--shadow-lg);
}

.welcome-section h1 {
  color: white;
  font-size: 2.2rem;
  margin-bottom: 0.5rem;
}

.welcome-section p {
  color: rgba(255,255,255,0.9);
  font-size: 1.1rem;
  margin: 0;
}

.dashboard-sidebar {
  background: white;
  border-radius: 12px;
  box-shadow: var(--shadow-md);
  padding: 1.5rem;
  margin-bottom: 2rem;
  border-left: 4px solid #6366f1;
}

.dashboard-sidebar h3 {
  margin-top: 0;
  color: #0f172a;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.quick-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
  margin: 1.5rem 0;
}

.quick-stat {
  background: #f0f4ff;
  padding: 1rem;
  border-radius: 8px;
  text-align: center;
}

.quick-stat-number {
  font-size: 1.8rem;
  font-weight: 700;
  color: #6366f1;
}

.quick-stat-label {
  font-size: 0.85rem;
  color: #64748b;
  margin-top: 0.5rem;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2rem;
  padding: 0;
}

.dashboard-card {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: var(--shadow-md);
  text-align: center;
  transition: var(--transition);
  border-top: 4px solid #6366f1;
  cursor: pointer;
  display: flex;
  flex-direction: column;
}

.attendance-actions .btn {
  min-width: 160px;
}

.dashboard-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-lg);
  border-top-color: #8b5cf6;
}

  .meeting-panel {
    margin-top: 2rem;
    background: white;
    border-radius: 18px;
    box-shadow: var(--shadow-md);
    padding: 1.75rem;
  }

  .meeting-panel-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .meeting-tabs {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .meeting-tab {
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    color: #0f172a;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    transition: var(--transition);
    font-weight: 700;
  }

  .meeting-tab.active {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: white;
    border-color: transparent;
  }

  .meeting-panel-content {
    display: none;
    gap: 1.5rem;
  }

  .meeting-panel-content.active {
    display: block;
  }

  .meeting-card {
    padding: 1.5rem;
    border-radius: 16px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    margin-bottom: 1rem;
  }

  .meeting-card-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 1rem;
  }

  .meeting-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .participant-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1rem;
    text-align: left;
  }

  .participant-card h4 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .participant-status {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: #16a34a;
  }

  .meeting-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .meeting-actions .btn {
    min-width: 140px;
  }

  .meeting-create-panel {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .meeting-create-info {
    background: #eef2ff;
    padding: 1.25rem;
    border-radius: 14px;
    border: 1px solid #e0e7ff;
  }

  .meeting-create-info h3 {
    margin-top: 0;
  }

  background-clip: text;
}

.dashboard-card h3 {
  margin: 1rem 0 0.5rem;
  color: #0f172a;
}

.dashboard-card p {
  color: #64748b;
  font-size: 0.95rem;
  margin: 0.5rem 0 1.5rem;
  flex-grow: 1;
}

.card-btn {
  align-self: center;
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="logo"><i class="fas fa-graduation-cap"></i> AcademiaPro</div>
  <div class="nav-links">
    <span onclick="window.location.href='/dashboard'"><i class="fas fa-home"></i> Dashboard</span>
    <span onclick="window.location.href='/jobs'"><i class="fas fa-briefcase"></i> Jobs</span>
    <span onclick="window.location.href='/profile'"><i class="fas fa-user"></i> Profile</span>
    <span onclick="window.location.href='/meetings'"><i class="fas fa-video"></i> Meetings</span>
    <% if (user.role === 'hr') { %><span onclick="window.location.href='/office'"><i class="fas fa-building"></i> Office</span><% } %>
    <% if (user.role === 'admin') { %><span onclick="window.location.href='/admin'"><i class="fas fa-cog"></i> Admin</span><% } %>
    <form action="/logout" method="POST" style="display:inline;">
      <button type="submit" style="background:none;border:none;color:#cbd5e1;cursor:pointer;font-weight:500;transition:var(--transition);" onmouseover="this.style.color='#6366f1'" onmouseout="this.style.color='#cbd5e1'"><i class="fas fa-sign-out-alt"></i> Logout</button>
    </form>
  </div>
</nav>

<div class="container">
  <!-- WELCOME SECTION -->
  <div class="welcome-section">
    <h1><i class="fas fa-wave-hand"></i> Welcome back, <%= user.name %>!</h1>
    <p>Navigate and explore your opportunities with AcademiaPro</p>
  </div>

  <!-- QUICK STATS -->
  <div class="dashboard-sidebar">
    <h3><i class="fas fa-chart-bar"></i> Your Activity</h3>
    <div class="quick-stats">
      <div class="quick-stat">
        <div class="quick-stat-number"><%= stats.applications %></div>
        <div class="quick-stat-label">Applications</div>
      </div>
      <div class="quick-stat">
        <div class="quick-stat-number"><%= stats.interviews %></div>
        <div class="quick-stat-label">Interviews</div>
      </div>
      <div class="quick-stat">
        <div class="quick-stat-number"><%= stats.offers %></div>
        <div class="quick-stat-label">Completed</div>
      </div>
      <div class="quick-stat">
        <div class="quick-stat-number"><%= stats.favorites %></div>
        <div class="quick-stat-label">Favorites</div>
      </div>
    </div>
  </div>

  <div style="padding: 0 0 2rem;">
      <h2 style="font-size: 1.8rem; margin-bottom: 2rem;"><i class="fas fa-th-large"></i> What would you like to do?</h2>
      <div class="dashboard-grid">
      <div class="dashboard-card" onclick="window.location.href='/jobs'">
        <i class="fas fa-briefcase"></i>
        <h3>Browse Jobs</h3>
        <p>Explore faculty and professor positions from top universities worldwide.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> View All Jobs</button>
      </div>

      <div class="dashboard-card" onclick="window.location.href='/profile'">
        <i class="fas fa-user-circle"></i>
        <h3>My Profile</h3>
        <p>View your applications, interviews, and career profile information.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Go to Profile</button>
      </div>

      <div class="dashboard-card" onclick="window.location.href='/meetings'">
        <i class="fas fa-video"></i>
        <h3>Meeting Center</h3>
        <p>Open the dedicated meeting workspace for scheduling, links, and live interview access.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Open Meetings</button>
      </div>

      <div class="dashboard-card" onclick="window.location.href='/candidate/portal'">
        <i class="fas fa-video"></i>
        <h3>Live Interview Room</h3>
        <p>Join your candidate video interview portal and start the live session.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Open Portal</button>
      </div>
        <i class="fas fa-heart"></i>
        <h3>Saved Jobs</h3>
        <p>Keep track of the positions you want to revisit later.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> View Saved Jobs</button>
      </div>

      <div class="dashboard-card" onclick="document.getElementById('resumeModal').style.display='block'">
        <i class="fas fa-file-upload"></i>
        <h3>Upload Resume</h3>
        <p>Upload or update your resume for faster job applications.</p>
        <button class="btn btn-primary card-btn" type="button"><i class="fas fa-upload"></i> Upload Resume</button>
      </div>

      <% if (user.resume_review_status) { %>
      <div class="dashboard-card" onclick="window.location.href='/profile'">
        <i class="fas fa-file-alt"></i>
        <h3>Resume Review Status</h3>
        <p><%= user.resume_review_status === 'pending' ? 'Your resume is under admin review.' : user.resume_review_status === 'shortlisted' ? 'Your resume has been approved by admin.' : 'Your resume was rejected. Upload a fresh version for review.' %></p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> View Resume</button>
      </div>
      <% } %>

      <% if (user.role === 'admin') { %>
      <div class="dashboard-card" onclick="window.location.href='/admin'">
        <i class="fas fa-check-circle"></i>
        <h3>Resume Shortlisting</h3>
        <p>Review and shortlist candidate applications for faculty positions.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Manage Applications</button>
      </div>

      <div class="dashboard-card" onclick="window.location.href='/shortlisted'">
        <i class="fas fa-file-alt"></i>
        <h3>Shortlisted Resumes</h3>
        <p>View and download resumes of shortlisted candidates.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> View Resumes</button>
      </div>
      <% } %>
      <% if (user.role === 'hr') { %>
      <div class="dashboard-card" onclick="window.location.href='/office'">
        <i class="fas fa-building"></i>
        <h3>HR Portal</h3>
        <p>Access the office dashboard and shortlisted candidate resumes.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Open Office</button>
      </div>
      <% } %>

      <div class="dashboard-card" onclick="window.location.href='/jobs'">
        <i class="fas fa-chart-line"></i>
        <h3>Compare Jobs</h3>
        <p>Compare multiple job offers side-by-side to make the best decision.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Start Comparing</button>
      </div>

      <div class="dashboard-card" onclick="window.location.href='/profile'">
        <i class="fas fa-robot"></i>
        <h3>AI Interview Prep</h3>
        <p>Practice with AI-powered interview questions and get instant feedback.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Start Interview</button>
      </div>

      <div class="dashboard-card" onclick="window.location.href='/jobs'">
        <i class="fas fa-bell"></i>
        <h3>Job Alerts</h3>
        <p>Get notifications for jobs matching your profile and preferences.</p>
        <button class="btn btn-primary card-btn"><i class="fas fa-arrow-right"></i> Manage Alerts</button>
      </div>
    </div>
  </div>

  <div class="meeting-panel">
    <div class="meeting-panel-header">
      <div>
        <h2><i class="fas fa-video"></i> Interview Meetings</h2>
        <p>Attend scheduled sessions from your dashboard.</p>
      </div>
      <% if (user.role === 'hr' || user.role === 'admin') { %>
      <div class="meeting-tabs">
        <button class="meeting-tab active" data-target="attend">Attend Meeting</button>
        <button class="meeting-tab" data-target="create">Create Meeting Link</button>
      </div>
      <% } %>
    </div>

    <div id="meeting-panel-attend" class="meeting-panel-content active">
      <% if (meetings && meetings.length) { %>
        <% meetings.forEach(meeting => { %>
          <div class="meeting-card">
            <div class="meeting-card-header">
              <div>
                <h3><%= meeting.job_title || 'Interview Meeting' %> <span style="font-size:0.9rem; color:#64748b; display:block;">(<%= meeting.university || 'University' %>)</span></h3>
                <p><strong>Scheduled:</strong> <%= new Date(meeting.scheduled_at).toLocaleString() %></p>
                <p><strong>Platform:</strong> <%= meeting.platform ? meeting.platform.toUpperCase() : 'JITSI' %></p>
              </div>
              <div class="attendance-actions">
                <a href="/meeting/<%= meeting.id %>/join-redirect" class="btn btn-primary" style="text-decoration:none;">Join Meeting</a>
                <% if (meeting.meeting_link) { %>
                <a href="<%= meeting.meeting_link %>" target="_blank" class="btn btn-secondary" style="text-decoration:none;">Open Jitsi</a>
                <% } %>
              </div>
            </div>

            <div class="meeting-row">
              <% const attendees = meeting.participants && meeting.participants.length ? meeting.participants.slice(0, 3) : [
                   { name: meeting.candidate_name || 'Candidate', role: 'candidate', email: meeting.candidate_email },
                   { name: 'HR Representative', role: 'hr' },
                   { name: 'Admin', role: 'admin' }
                 ];
                 while (attendees.length < 3) attendees.push({ name: 'Pending participant', role: 'participant' });
              %>
              <% attendees.forEach(member => { %>
              <div class="participant-card">
                <h4><i class="fas fa-user-circle"></i> <%= member.name %></h4>
                <p><strong>Role:</strong> <%= member.role ? member.role.charAt(0).toUpperCase() + member.role.slice(1) : 'Participant' %></p>
                <% if (member.email) { %><p><strong>Email:</strong> <%= member.email %></p><% } %>
                <div class="participant-status"><i class="fas fa-circle"></i> Active</div>
              </div>
              <% }); %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="meeting-create-info">
          <h3>No scheduled meetings found</h3>
          <p>There are currently no upcoming interview meetings for your account. Use the create tab to start a new session or check your portal.</p>
        </div>
      <% } %>
    </div>

    <% if (user.role === 'hr' || user.role === 'admin') { %>
    <div id="meeting-panel-create" class="meeting-panel-content">
      <div class="meeting-create-panel">
        <div class="meeting-create-info">
          <h3>Create a new meeting link</h3>
          <p>Schedule a Jitsi or custom meeting from your portal. Create and share links with candidates directly from the HR/Admin workspace.</p>
        </div>
        <div class="meeting-actions">
          <button class="btn btn-primary" onclick="window.location.href='/meetings'">Open Meeting Center</button>
          <button class="btn btn-secondary" onclick="window.location.href='/candidate/portal'">View Candidate Portal</button>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <script>
    document.querySelectorAll('.meeting-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.meeting-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.meeting-panel-content').forEach(panel => panel.classList.remove('active'));
        tab.classList.add('active');
        const target = tab.getAttribute('data-target');
        document.getElementById(`meeting-panel-${target}`).classList.add('active');
      });
    });
  </script>

  <!-- FEATURED OPPORTUNITIES -->
  <div class="section" style="margin-top: 3rem; margin-bottom: 3rem;">
    <h2 style="font-size: 1.8rem; margin-bottom: 1.5rem;"><i class="fas fa-star"></i> Featured Opportunities</h2>
    <div class="dashboard-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
      <div style="background: white; padding: 1.5rem; border-radius: 12px; box-shadow: var(--shadow-md); border-left: 4px solid #6366f1;">
        <h4 style="color: #6366f1; margin-top: 0;">Senior Professor - Computer Science</h4>
        <p style="margin: 0.5rem 0; color: #64748b;"><i class="fas fa-school"></i> Stanford University</p>
        <p style="margin: 0.5rem 0; color: #64748b;"><i class="fas fa-map-marker-alt"></i> California, USA</p>
        <p style="font-weight: 600; margin: 1rem 0; color: #6366f1;"><i class="fas fa-dollar-sign"></i> $120,000 - $180,000</p>
        <button class="btn btn-primary" style="width: 100%;"><i class="fas fa-arrow-right"></i> View Details</button>
      </div>

      <div style="background: white; padding: 1.5rem; border-radius: 12px; box-shadow: var(--shadow-md); border-left: 4px solid #8b5cf6;">
        <h4 style="color: #8b5cf6; margin-top: 0;">Associate Professor - Data Science</h4>
        <p style="margin: 0.5rem 0; color: #64748b;"><i class="fas fa-school"></i> MIT</p>
        <p style="margin: 0.5rem 0; color: #64748b;"><i class="fas fa-map-marker-alt"></i> Massachusetts, USA</p>
        <p style="font-weight: 600; margin: 1rem 0; color: #8b5cf6;"><i class="fas fa-dollar-sign"></i> $100,000 - $160,000</p>
        <button class="btn btn-primary" style="width: 100%;"><i class="fas fa-arrow-right"></i> View Details</button>
      </div>

      <div style="background: white; padding: 1.5rem; border-radius: 12px; box-shadow: var(--shadow-md); border-left: 4px solid #10b981;">
        <h4 style="color: #10b981; margin-top: 0;">Lecturer - Engineering</h4>
        <p style="margin: 0.5rem 0; color: #64748b;"><i class="fas fa-school"></i> Cambridge University</p>
        <p style="margin: 0.5rem 0; color: #64748b;"><i class="fas fa-map-marker-alt"></i> Cambridge, UK</p>
        <p style="font-weight: 600; margin: 1rem 0; color: #10b981;"><i class="fas fa-dollar-sign"></i> £60,000 - £90,000</p>
        <button class="btn btn-primary" style="width: 100%;"><i class="fas fa-arrow-right"></i> View Details</button>
      </div>
    </div>
  </div>
</div>

<!-- RESUME UPLOAD MODAL -->
<div id="resumeModal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5);">
  <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 2rem; border-radius: 12px; box-shadow: var(--shadow-2xl); width: 90%; max-width: 500px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h3 style="margin: 0; color: #0f172a;"><i class="fas fa-file-upload"></i> Upload Your Resume</h3>
      <button onclick="document.getElementById('resumeModal').style.display='none'" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">&times;</button>
    </div>
    
    <form action="/profile/resume" method="POST" enctype="multipart/form-data">
      <div style="margin-bottom: 1.5rem;">
        <label for="resume" style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: #1e293b;">
          <i class="fas fa-file-upload"></i> Select Resume File
        </label>
        <input type="file" id="resume" name="resume" accept=".pdf,image/*" required 
               style="width: 100%; padding: 1rem; border: 2px dashed #cbd5e1; border-radius: 8px; background: #f8fafc; transition: var(--transition); cursor: pointer;">
        <small style="color: #64748b; font-size: 0.85rem; margin-top: 0.5rem; display: block;">
          <i class="fas fa-info-circle"></i> Maximum file size: 5MB. Accepted formats: PDF, JPG, PNG
        </small>
      </div>
      
      <div style="display: flex; gap: 1rem; justify-content: flex-end;">
        <button type="button" onclick="document.getElementById('resumeModal').style.display='none'" 
                style="padding: 0.75rem 1.5rem; background: #f3f4f6; color: #374151; border: none; border-radius: 8px; cursor: pointer; font-weight: 500;">
          Cancel
        </button>
        <button type="submit" class="btn btn-primary" style="border: none;">
          <i class="fas fa-upload"></i> Upload Resume
        </button>
      </div>
    </form>
  </div>
</div>

<script>
// Close modal when clicking outside
window.onclick = function(event) {
  const modal = document.getElementById('resumeModal');
  if (event.target == modal) {
    modal.style.display = "none";
  }
}

// File input styling
const resumeInput = document.getElementById('resume');
if (resumeInput) {
  resumeInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      // You could add file validation here
      console.log('Selected file:', file.name);
    }
  });
}
</script>

</body>
</html>