  {av:'DP',c:'av-blue',name:'Divya Pandey',email:'divya@email.com',pos:'Backend',score:4.0,date:'May 18',status:'pending'},
];
function buildCandidates(){
  const query=document.getElementById('candidateSearchInput').value.trim().toLowerCase();
  const positionFilter=document.getElementById('candidatePositionFilter').value;
  const statusFilter=document.getElementById('candidateStatusFilter').value;
  const body=document.getElementById('candidatesBody');body.innerHTML='';
  const filtered=candidateData.filter(c=>{
    const matchesQuery=!query||[c.name,c.email,c.pos].some(v=>v.toLowerCase().includes(query));
    const matchesPosition=positionFilter==='All Positions'||c.pos===positionFilter;
    const labelStatus=c.status==='hold'?'On Hold':c.status.charAt(0).toUpperCase()+c.status.slice(1);
    const matchesStatus=statusFilter==='All Status'||labelStatus===statusFilter||c.status===statusFilter.toLowerCase();
    return matchesQuery&&matchesPosition&&matchesStatus;
  });
  const subtitle = !query && positionFilter==='All Positions' && statusFilter==='All Status'
    ? `${filtered.length} candidates across all positions`
    : `${filtered.length} candidates matching your search`;
  document.getElementById('candidatePageSub').textContent=subtitle;
  if(!filtered.length){
    body.innerHTML='<div class="table-row" style="grid-template-columns:1fr;justify-items:center;color:var(--muted);">No candidates found.</div>';
    return;
  }
  filtered.forEach(c=>{
    const statusMap={accepted:['status-completed','✓ Accepted'],pending:['status-pending','Pending'],hold:['status-pending','On Hold'],rejected:['status-scheduled','✗ Rejected']};
    const [scls,slabel]=statusMap[c.status]||['status-pending','Pending'];
    const scoreClass=c.score>=4.2?'high':c.score>=3.5?'mid':'low';
    const avStyle=c.sc?`background:${c.sc};color:${c.tc};`:'';
    const row=document.createElement('div');row.className='table-row';
    row.innerHTML=`
      <div class="td"><div class="cand-info"><div class="cand-av ${c.c}" style="${avStyle}">${c.av}</div><div><div class="cand-name">${c.name}</div><div class="cand-email">${c.email}</div></div></div></div>
      <div class="td" style="color:var(--label);font-size:0.82rem;">${c.pos}</div>
      <div class="td"><div class="score-pill ${scoreClass}">★ ${c.score}</div></div>
      <div class="td" style="color:var(--muted);font-size:0.78rem;">${c.date}</div>
      <div class="td"><div class="iv-status ${scls}">${slabel}</div></div>
      <div class="td"><div class="row-actions"><button class="row-btn green" onclick="quickStartInterview('${c.name}')">▶ Start</button><button class="row-btn" onclick="showToast('📄 Opening ${c.name} profile…')">View</button></div></div>
    `;
    body.appendChild(row);
  });
}
function buildReportEvals(){
  const div=document.getElementById('reportEvals');div.innerHTML='';
  candidateData.slice(0,4).forEach(c=>{
    const scoreClass=c.score>=4.2?'high':c.score>=3.5?'mid':'low';
    const avStyle=c.sc?`background:${c.sc};color:${c.tc};`:'';
    div.innerHTML+=`<div class="interview-row" style="padding:12px 20px;margin:0;" onclick="showToast('Opening ${c.name} evaluation…')">
      <div class="iv-av ${c.c}" style="${avStyle}">${c.av}</div>
      <div class="iv-info"><div class="iv-name">${c.name}</div><div class="iv-meta">${c.pos} · ${c.date}</div></div>
      <div class="score-pill ${scoreClass}" style="margin-right:12px;">★ ${c.score}</div>
      <div class="iv-status ${c.status==='accepted'?'status-completed':c.status==='rejected'?'status-scheduled':'status-pending'}">${c.status}</div>
    </div>`;
  });
}

