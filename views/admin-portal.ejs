<script>
// ══════════════════════ STATE ══════════════════════
let localStream=null,micOn=true,camOn=true,screenSharing=false,recording=false;
let timerInterval=null,seconds=0;
let sidebarVisible=true;
let currentRole='interviewer';
let currentDecision=null;
let currentView='dashboard';
let viewHistory=['dashboard'];
const scoreCategories=['Technical Knowledge','Communication','Problem Solving','Culture Fit','Experience'];
let scores={};
scoreCategories.forEach(c=>scores[c]=0);

// ══════════════════════ PARTICLES ══════════════════════
(function(){
  const bg=document.getElementById('particleBg');
  for(let i=0;i<14;i++){
    const p=document.createElement('div');p.className='particle';
    p.style.cssText=`left:${Math.random()*100}vw;width:${Math.random()*3+1}px;height:${Math.random()*3+1}px;animation-duration:${Math.random()*12+8}s;animation-delay:${Math.random()*10}s;`;
    bg.appendChild(p);
  }
})();

// ══════════════════════ NAVIGATION ══════════════════════
function navigateTo(page){
  document.querySelectorAll('.page').forEach(p=>p.style.display='none');
  if(page==='lobby'){
    document.getElementById('page-lobby').style.display='flex';
  } else if(page==='dashboard'){
    document.getElementById('page-app').style.display='flex';
    showView('dashboard');
  } else if(page==='room'){
    document.getElementById('page-room').style.display='flex';
  }
}

function showView(view){
  document.querySelectorAll('.content-view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const el=document.getElementById('view-'+view);
  if(el) el.classList.add('active');
  const nav=document.getElementById('nav-'+view);
  if(nav) nav.classList.add('active');

  const labels={dashboard:'Dashboard',newinterview:'New Interview',schedule:'Schedule',candidates:'Candidates',reports:'Reports',recordings:'Recordings',settings:'Settings',help:'Help'};
  document.getElementById('crumbActive').textContent=labels[view]||view;

  if(view!=='dashboard'){
    document.getElementById('backBtn').style.display='flex';
  } else {
    document.getElementById('backBtn').style.display='none';
  }

  if(viewHistory[viewHistory.length-1]!==view) viewHistory.push(view);
  currentView=view;

  if(view==='schedule') buildCalendar();
  if(view==='candidates') buildCandidates();
  if(view==='reports') buildReportEvals();
  if(view==='recordings') buildRecordings();
  if(view==='settings') buildSettings('profile');

  document.getElementById('page-app').style.display='flex';
}

function goBack(){
  if(viewHistory.length>1){
    viewHistory.pop();
    const prev=viewHistory[viewHistory.length-1];
    showView(prev);
  } else {
    showView('dashboard');
  }
}

// ══════════════════════ LOBBY ══════════════════════
function switchRole(role){
  currentRole=role;
  document.getElementById('tab-interviewer').classList.toggle('active',role==='interviewer');
  document.getElementById('tab-candidate').classList.toggle('active',role==='candidate');
  document.getElementById('interviewer-fields').style.display=role==='interviewer'?'flex':'none';
  document.getElementById('candidate-fields').style.display=role==='candidate'?'flex':'none';
}

function hostMeeting(){
  const name=document.getElementById('interviewer-name').value.trim()||'Interviewer';
  const pos=document.getElementById('position').value.trim()||'Position';
  enterRoom(name,'interviewer',pos);
}

function joinMeeting(){
  const name=document.getElementById('candidate-name').value.trim()||'Candidate';
  enterRoom(name,'candidate','Full Stack Developer — Batch 2026');
}

function quickDemo(){
  enterRoom('Prof. Sarah Johnson','interviewer','Full Stack Developer — Batch 2026');
}

// ══════════════════════ ROOM ══════════════════════
function enterRoom(name,role,position){
  navigateTo('room');
  document.getElementById('room-title').textContent=position;
  document.getElementById('info-position').textContent=position;

  const initials=name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  document.getElementById('localTileName').textContent=name;
  document.getElementById('localNameDisplay').textContent=name;
  document.getElementById('localAvatarLetter').textContent=initials;
  document.getElementById('localBadge').textContent=role==='interviewer'?'INTERVIEWER':'CANDIDATE';

  if(role==='interviewer'){
    document.getElementById('info-interviewer').textContent=name;
    document.getElementById('sideUserName').textContent=name;
    document.getElementById('sideUserAv').textContent=initials;
    document.getElementById('topUserAv').textContent=initials;
    setTimeout(()=>{
      document.getElementById('waiting-overlay').style.display='flex';
    },2500);
  } else {
    document.getElementById('info-candidate').textContent=name;
    document.getElementById('remoteTileName').textContent='Interviewer';
    document.getElementById('remoteName').textContent='Interviewer';
  }
  buildScoreSection();
  initCamera();
  startTimer();
}

function hostFromDash(){
  const name=document.getElementById('ni-name').value.trim()||'Interviewer';
  const pos=document.getElementById('ni-pos').value.trim()||'Position';
  enterRoom(name,'interviewer',pos);
}

function joinFromDash(){
  const name=document.getElementById('ni-cname').value.trim()||'Candidate';
  enterRoom(name,'candidate','Full Stack Developer — Batch 2026');
}

function quickStartInterview(candidateName){
  document.getElementById('remoteTileName').textContent=candidateName;
  document.getElementById('remoteName').textContent=candidateName;
  document.getElementById('info-candidate').textContent=candidateName;
  enterRoom('Prof. Sarah Johnson','interviewer','Full Stack Developer — Batch 2026');
}

function leaveRoom(){
  if(confirm('Leave the interview session?')){
    if(localStream) localStream.getTracks().forEach(t=>t.stop());
    clearInterval(timerInterval);
    navigateTo('dashboard');
    showToast('Session ended · Returning to dashboard');
  }
}

function endCall(){
  if(confirm('End the interview session?')){
    if(localStream) localStream.getTracks().forEach(t=>t.stop());
    clearInterval(timerInterval);
    navigateTo('dashboard');
    showToast('✅ Session ended · Evaluation saved');
  }
}

function admitCandidate(){
  document.getElementById('waiting-overlay').style.display='none';
  document.getElementById('remoteVideoOff').style.display='none';
  showToast('✓ Candidate admitted to session');
  simulateRemoteVideo();
}

function denyCandidate(){
  document.getElementById('waiting-overlay').style.display='none';
  showToast('✕ Candidate denied entry');
}

function simulateRemoteVideo(){
  const tile=document.getElementById('tile-candidate');
  const canvas=document.createElement('canvas');
  canvas.width=640;canvas.height=480;
  canvas.style.cssText='width:100%;height:100%;object-fit:cover;';
  const ctx=canvas.getContext('2d');
  let hue=160;
  const animate=()=>{
    hue=(hue+0.3)%360;
    const g=ctx.createLinearGradient(0,0,640,480);
    g.addColorStop(0,`hsl(${hue},35%,18%)`);
    g.addColorStop(1,`hsl(${hue+40},25%,12%)`);
    ctx.fillStyle=g;ctx.fillRect(0,0,640,480);
    ctx.fillStyle=`hsl(${hue},20%,28%)`;
    ctx.beginPath();ctx.arc(320,180,70,0,Math.PI*2);ctx.fill();
    ctx.fillRect(220,250,200,180);
    requestAnimationFrame(animate);
  };animate();
  tile.insertBefore(canvas,tile.querySelector('.tile-bottom'));
}

// ══════════════════════ CAMERA ══════════════════════
async function initCamera(){
  try{
    localStream=await navigator.mediaDevices.getUserMedia({video:true,audio:true});
    document.getElementById('localVideo').srcObject=localStream;
    document.getElementById('localVideoOff').style.display='none';
  }catch(e){
    document.getElementById('localVideoOff').style.display='flex';
    showToast('📷 Camera unavailable — showing avatar');
  }
}

// ══════════════════════ CONTROLS ══════════════════════
function toggleMic(){
  micOn=!micOn;
  if(localStream) localStream.getAudioTracks().forEach(t=>t.enabled=micOn);
  document.getElementById('micBtn').classList.toggle('off',!micOn);
  document.getElementById('micIcon').textContent=micOn?'🎤':'🔇';
  document.getElementById('localMicOff').style.display=micOn?'none':'flex';
  showToast(micOn?'🎤 Microphone on':'🔇 Muted');
}
function toggleCamera(){
  camOn=!camOn;
  if(localStream) localStream.getVideoTracks().forEach(t=>t.enabled=camOn);
  document.getElementById('camBtn').classList.toggle('off',!camOn);
  document.getElementById('camIcon').textContent=camOn?'📹':'📷';
  document.getElementById('localVideoOff').style.display=camOn?'none':'flex';
  document.getElementById('localVideo').style.display=camOn?'block':'none';
  showToast(camOn?'📹 Camera on':'📷 Camera off');
}
async function toggleScreenShare(){
  if(!screenSharing){
    try{
      const ss=await navigator.mediaDevices.getDisplayMedia({video:true});
      document.getElementById('localVideo').srcObject=ss;
      document.getElementById('localVideoOff').style.display='none';
      document.getElementById('screenBtn').classList.add('off');
      document.getElementById('screenIcon').textContent='🛑';
      screenSharing=true;
      showToast('🖥️ Screen sharing started');
      ss.getVideoTracks()[0].onended=()=>stopScreenShare();
    }catch(e){showToast('Screen share cancelled');}
  } else stopScreenShare();
}
function stopScreenShare(){
  screenSharing=false;
  document.getElementById('screenBtn').classList.remove('off');
  document.getElementById('screenIcon').textContent='🖥️';
  if(localStream) document.getElementById('localVideo').srcObject=localStream;
  showToast('🛑 Screen sharing stopped');
}
function toggleRecording(){
  recording=!recording;
  document.getElementById('rec-badge').style.display=recording?'flex':'none';
  document.getElementById('recBtn').textContent=recording?'⏹ Stop':'🔴 Record';
  showToast(recording?'🔴 Recording started':'⏹ Recording stopped');
}
function copyRoomLink(){
  navigator.clipboard.writeText('https://interviewlink.app/join/IVW-2026-7834').catch(()=>{});
  showToast('🔗 Invite link copied!');
}

// ══════════════════════ TIMER ══════════════════════
function startTimer(){
  clearInterval(timerInterval);seconds=0;
  timerInterval=setInterval(()=>{
    seconds++;
    const m=String(Math.floor(seconds/60)).padStart(2,'0');
    const s=String(seconds%60).padStart(2,'0');
    document.getElementById('room-timer').textContent=m+':'+s;
  },1000);
}

// ══════════════════════ SIDEBAR (room) ══════════════════════
function toggleSidebar(){
  sidebarVisible=!sidebarVisible;
  document.getElementById('room-sidebar').classList.toggle('hidden',!sidebarVisible);
  document.getElementById('notesToggleBtn').classList.toggle('active-btn',sidebarVisible);
}
function showSidebar(){
  sidebarVisible=true;
  document.getElementById('room-sidebar').classList.remove('hidden');
  document.getElementById('notesToggleBtn').classList.add('active-btn');
}
function switchPanel(name){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.stab').forEach(t=>t.classList.remove('active'));
  document.getElementById('panel-'+name).classList.add('active');
  document.getElementById('stab-'+name).classList.add('active');
