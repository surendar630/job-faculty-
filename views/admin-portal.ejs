// ══════════════════════ CHAT ══════════════════════
function handleChatKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat();}}
function sendChat(){
  const input=document.getElementById('chatInput');
  const text=input.value.trim();if(!text)return;
  input.value='';
  const container=document.getElementById('chatMessages');
  const div=document.createElement('div');div.className='msg mine';
  div.innerHTML=`<div class="msg-header"><span>now</span><span class="msg-sender">You</span></div><div class="msg-bubble">${escHtml(text)}</div>`;
  container.appendChild(div);container.scrollTop=container.scrollHeight;
  setTimeout(()=>simulateReply(container),1500);
}
function simulateReply(container){
  const replies=[
    "That's a great point. Can you elaborate on your React experience?",
    "Walk me through a challenging project you've completed.",
    "How do you approach system design for high-traffic applications?",
    "Tell me about your database experience — SQL and NoSQL?",
    "How would you handle tight deadlines with changing requirements?",
    "What's your approach to code review and testing?",
    "Describe your experience with CI/CD pipelines.",
  ];
  const div=document.createElement('div');div.className='msg';
  div.innerHTML=`<div class="msg-header"><span class="msg-sender">Prof. Johnson</span><span>now</span></div><div class="msg-bubble">${replies[Math.floor(Math.random()*replies.length)]}</div>`;
  container.appendChild(div);container.scrollTop=container.scrollHeight;
}
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

// ══════════════════════ EVALUATION ══════════════════════
function buildScoreSection(){
  const sec=document.getElementById('scoreSection');sec.innerHTML='';
  scoreCategories.forEach(cat=>{
    const row=document.createElement('div');row.className='score-row';
    const stars=[1,2,3,4,5].map(i=>`<div class="star" onclick="setScore('${cat}',${i})" id="star-${cat.replace(/\s/g,'_')}-${i}">★</div>`).join('');
    row.innerHTML=`<div class="score-label">${cat}</div><div class="score-stars">${stars}</div>`;
    sec.appendChild(row);
  });
}
function setScore(cat,val){
  scores[cat]=val;
  [1,2,3,4,5].forEach(i=>{
    const s=document.getElementById(`star-${cat.replace(/\s/g,'_')}-${i}`);
    if(s) s.classList.toggle('filled',i<=val);
  });
}
function setDecision(btn,decision){
  currentDecision=decision;
  document.querySelectorAll('.dec-btn').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected');
}
function exportEvaluation(){
  const notes=document.getElementById('notesArea').value;
  const lines=Object.entries(scores).map(([k,v])=>`${k}: ${'★'.repeat(v)}${'☆'.repeat(5-v)} (${v}/5)`).join('\n');
  const avg=(Object.values(scores).reduce((a,b)=>a+b,0)/scoreCategories.length).toFixed(1);
  const text=`INTERVIEW EVALUATION REPORT\n${'='.repeat(40)}\nPosition: Full Stack Developer\nDate: ${new Date().toLocaleDateString()}\nDuration: ${document.getElementById('room-timer').textContent}\n\nSCORES\n------\n${lines}\n\nAVERAGE: ${avg}/5\nDECISION: ${(currentDecision||'Not set').toUpperCase()}\n\nNOTES\n-----\n${notes||'(none)'}`;
  const blob=new Blob([text],{type:'text/plain'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`evaluation-${Date.now()}.txt`;a.click();
  showToast('📄 Evaluation exported!');
}

// ══════════════════════ CALENDAR ══════════════════════
function buildCalendar(){
  const body=document.getElementById('calBody');body.innerHTML='';
  const today=new Date();
  const year=today.getFullYear();const month=today.getMonth();
  const first=new Date(year,month,1).getDay();
  const days=new Date(year,month+1,0).getDate();
  const events={
    [today.getDate()]:[{label:'Alex Sharma 2PM',cls:'ev-blue'},{label:'Priya Patel 3:30PM',cls:'ev-green'}],
    [(today.getDate()+1)%days||1]:[{label:'Rahul Kumar 10AM',cls:'ev-yellow'}],
    [(today.getDate()-2+days)%days||1]:[{label:'Sneha Nair — Done',cls:'ev-green'}],
  };
  for(let i=0;i<first;i++){
    const cell=document.createElement('div');cell.className='cal-cell';cell.style.background='rgba(0,0,0,0.2)';
    body.appendChild(cell);
  }
  for(let d=1;d<=days;d++){
    const cell=document.createElement('div');
    cell.className='cal-cell'+(d===today.getDate()?' today':'');
    let html=`<div class="cal-date">${d}</div>`;
    (events[d]||[]).forEach(ev=>html+=`<div class="cal-event ${ev.cls}">${ev.label}</div>`);
    cell.innerHTML=html;
    cell.onclick=()=>showToast(`📅 ${d} ${today.toLocaleString('default',{month:'long'})} selected`);
    body.appendChild(cell);
  }
}

