<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= role === 'hr' ? 'HR Live Interview Portal' : 'Candidate Live Interview Portal' %> - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root { --bg:#07101d; --surface:#101828; --surface2:#192a4d; --surface3:#0f172a; --border:#223248; --accent:#5b8dff; --accent2:#22c55e; --text:#f8fafc; --muted:#94a3b8; --radius:16px; --font-head:'Syne',sans-serif; --font-body:'DM Sans',sans-serif; }
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font-body);background:#020617;color:var(--text);min-height:100vh;}
.page{display:none;}
.page.active{display:block;}
.header{padding:22px 28px;background:linear-gradient(135deg,#0f172a,#111827);display:flex;align-items:center;justify-content:space-between;gap:16px;position:sticky;top:0;z-index:20;border-bottom:1px solid rgba(255,255,255,0.05);}
.brand{font-family:var(--font-head);font-size:1.35rem;font-weight:800;letter-spacing:-0.03em;color:#f8fafc;}
.role-badge{padding:10px 16px;border-radius:999px;background:rgba(79,70,229,0.16);color:#e0e7ff;font-size:0.85rem;font-weight:700;}
.header-actions {display:flex; gap:10px; align-items:center;}
.btn, .link-btn{border:none;border-radius:12px;padding:11px 18px;font-weight:700;cursor:pointer;font-family:var(--font-body);transition:all .18s ease;}
.btn{background:linear-gradient(135deg,var(--accent),#8b5cf6);color:#fff;}
.link-btn{background:rgba(255,255,255,0.05);color:var(--text);}
.btn:hover, .link-btn:hover{transform:translateY(-1px);}
.main{padding:28px;display:grid;grid-template-columns:1.4fr 0.9fr;gap:22px;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px;}
.card h2{font-family:var(--font-head);font-size:1.2rem;margin-bottom:12px;}
.card p{color:var(--muted);line-height:1.7;font-size:0.95rem;}
.meeting-card{background:rgba(59,130,246,0.06);border:1px solid rgba(96,165,250,0.18);border-radius:20px;padding:18px;margin-top:16px;}
.meeting-card h3{font-size:1rem;margin-bottom:8px;}
.meeting-meta{display:flex;flex-wrap:wrap;gap:12px;margin-top:12px;}
.meeting-meta span{background:rgba(255,255,255,0.05);padding:10px 14px;border-radius:14px;font-size:0.88rem;color:var(--muted);}
.participant-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:14px;}
.participant-card{background:rgba(255,255,255,0.05);border:1px solid rgba(148,163,184,0.18);border-radius:16px;padding:12px;}
.participant-card strong{display:block;margin-bottom:6px;font-size:0.95rem;}
.participant-card span{font-size:0.82rem;color:var(--muted);}
.meeting-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:16px;}
.meeting-actions button{flex:1 1 140px;}
.lobby-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.action-panel{display:flex;flex-direction:column;gap:16px;}
.field{display:flex;flex-direction:column;gap:6px;}
.field label{font-size:0.78rem;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;font-weight:700;}
.field input, .field select{background:rgba(255,255,255,0.03);border:1px solid var(--border);color:var(--text);padding:12px 14px;border-radius:12px;outline:none;font-size:0.95rem;}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.stat{background:rgba(255,255,255,0.03);border:1px solid var(--border);padding:18px;border-radius:14px;}
.stat-title{font-size:0.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;}
.stat-value{font-size:1.6rem;font-weight:800;}
.room{display:none;padding:28px;}
.room.active{display:block;}
.room-top{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:22px;}
.room-title{font-family:var(--font-head);font-size:1.5rem;}
.room-badge{padding:8px 14px;border-radius:999px;background:rgba(56,189,248,0.16);color:#dbeafe;font-size:0.85rem;font-weight:700;}
.video-grid{display:grid;grid-template-columns:1.2fr 0.8fr;gap:18px;}
.video-panel{background:var(--surface);border:1px solid var(--border);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;}
.video-preview{position:relative;background:#050816;min-height:320px;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:1rem;}
.video-preview video, .video-preview canvas{width:100%;height:100%;object-fit:cover;}
.video-meta{display:flex;justify-content:space-between;align-items:center;padding:16px;border-top:1px solid var(--border);color:var(--muted);font-size:0.9rem;}
.controls{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px;}
.control-btn{flex:1 1 120px;display:flex;align-items:center;justify-content:center;gap:8px;padding:14px 16px;border-radius:14px;border:1px solid var(--border);background:var(--surface2);color:var(--text);cursor:pointer;font-weight:700;}
.control-btn.off{opacity:.7;}
.sidebar{background:var(--surface);border:1px solid var(--border);border-radius:20px;display:flex;flex-direction:column;overflow:hidden;}
.sidebar-tabs{display:flex;gap:2px;background:rgba(255,255,255,0.03);}
.tab{flex:1;text-align:center;padding:14px 0;cursor:pointer;color:var(--muted);font-weight:700;}
.tab.active{color:var(--text);background:linear-gradient(135deg,var(--accent),var(--accent2));}
.panel{display:none;flex:1;padding:20px;overflow-y:auto;}
.panel.active{display:block;}
.chat-messages{display:flex;flex-direction:column;gap:12px;}
.msg{background:rgba(255,255,255,0.04);padding:12px 14px;border-radius:16px;}
.msg.mine{background:rgba(59,130,246,0.15);align-self:flex-end;}
.msg-header{display:flex;justify-content:space-between;gap:10px;font-size:0.78rem;color:var(--muted);margin-bottom:8px;}
.msg-bubble{white-space:pre-wrap;line-height:1.5;}
.chat-input-area{margin-top:16px;display:flex;gap:10px;}
.chat-input{flex:1;background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:14px;padding:12px 14px;color:var(--text);resize:none;min-height:80px;}
.send-btn{background:var(--accent);color:#fff;border:none;border-radius:14px;padding:0 18px;cursor:pointer;}
.notes-section{display:flex;flex-direction:column;gap:14px;}
.notes-section textarea{background:rgba(255,255,255,0.03);border:1px solid var(--border);color:var(--text);border-radius:16px;padding:14px;resize:none;min-height:140px;}
.info-block{background:rgba(255,255,255,0.03);padding:14px 16px;border-radius:16px;line-height:1.6;color:var(--muted);}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:rgba(15,23,42,0.96);color:#e2e8f0;padding:14px 20px;border-radius:999px;opacity:0;pointer-events:none;transition:opacity 0.2s ease;z-index:50;}
@media(max-width:1120px){.main{grid-template-columns:1fr;}.video-grid{grid-template-columns:1fr;}} 
@media(max-width:720px){.header, .main{padding:20px;} .video-meta{flex-direction:column;gap:10px;}.controls{flex-direction:column;}.chat-input-area{flex-direction:column;}.chat-input{min-height:100px;}}
</style>
</head>
<body>
<div class="header">
  <div>
    <div class="brand">AcademiaPro</div>
    <div class="role-badge"><%= role === 'hr' ? 'HR Interview Portal' : 'Candidate Interview Portal' %></div>
  </div>
  <div class="header-actions">
    <button class="link-btn" onclick="window.location.href='<%= role === 'hr' ? '/office' : '/dashboard' %>'">Back to <%= role === 'hr' ? 'Office' : 'Dashboard' %></button>
    <button class="btn" onclick="navigateTo('lobby')">Lobby</button>
  </div>
</div>
<div class="main">
  <div class="card page active" id="page-lobby">
    <div class="action-panel">
      <div class="card">
        <h2><%= role === 'hr' ? 'Host a live interview' : 'Join your interview session' %></h2>
        <p><%= role === 'hr' ? 'Run interviews live with candidates, manage meeting controls, chat, and evaluate in one unified portal.' : 'Join the live interview room, track your session, and use chat and notes during the meeting.' %></p>
      </div>
      <div class="field">
        <label><%= role === 'hr' ? 'Interviewer name' : 'Your name' %></label>
        <input id="participantName" type="text" value="<%= user.name %>" placeholder="Enter your name">
      </div>
      <div class="field">
        <label>Position / Role</label>
        <input id="sessionPosition" type="text" value="Faculty Interview — Fall 2026" placeholder="Interview subject">
      </div>
      <% if (role === 'hr') { %>
      <div class="field">
        <label>Candidate expected</label>
        <input id="candidateNameInput" type="text" value="Alex Sharma" placeholder="Candidate name">
      </div>
      <% } %>

      <% if (meetings && meetings.length) { %>
      <div class="card">
        <h2>Upcoming interview sessions</h2>
        <% meetings.forEach((meeting, index) => { %>
          <div class="meeting-card">
            <h3><%= meeting.job_title %> — <%= meeting.university || 'AcademiaPro Interview' %></h3>
            <div class="meeting-meta">
              <span><strong>Scheduled:</strong> <%= new Date(meeting.scheduled_at).toLocaleString() %></span>
              <span><strong>Platform:</strong> <%= meeting.platform || 'Jitsi' %></span>
              <span><strong>Status:</strong> <%= meeting.status || 'Scheduled' %></span>
            </div>
            <div class="participant-list">
              <% if (meeting.participants && meeting.participants.length) { %>
                <% meeting.participants.slice(0, 3).forEach((participant) => { %>
                  <div class="participant-card">
                    <strong><%= participant.name %></strong>
                    <span><%= participant.role || 'Participant' %></span>
                    <span><%= participant.email || 'No email' %></span>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="participant-card">
                  <strong><%= role === 'hr' ? 'HR / Interviewer' : 'Candidate' %></strong>
                  <span>Live interview participant</span>
                  <span>Waiting to join</span>
                </div>
              <% } %>
            </div>
            <div class="meeting-actions">
              <button class="btn" onclick="openScheduledMeeting('<%= meeting.id %>', <%- JSON.stringify(meeting.meeting_link || '') %>)">
                <% if (role === 'hr') { %>Open live room<% } else { %>Join meeting<% } %>
              </button>
              <button class="control-btn" onclick="copyInviteLink(<%- JSON.stringify(meeting.meeting_link || '') %>)">Copy link</button>
            </div>
          </div>
        <% }); %>
      </div>
      <% } %>

      <div class="controls">
        <% if (role === 'hr') { %>
          <button class="btn" onclick="hostMeeting()">🎥 Start Interview</button>
          <button class="control-btn" onclick="copyInvite()">🔗 Copy Invite Link</button>
        <% } else { %>
          <button class="btn" onclick="joinMeeting()">🚀 Join Interview</button>
          <button class="control-btn" onclick="copyInvite()">🔗 Copy Meeting Code</button>
        <% } %>
      </div>
    </div>
    <div class="card" style="background:linear-gradient(135deg,rgba(79,124,255,0.12),rgba(16,185,129,0.12));border:none;">
      <h2>Session overview</h2>
      <div class="stats-grid">
        <div class="stat"><div class="stat-title">Meeting code</div><div class="stat-value">IVW-2026-7834</div></div>
        <div class="stat"><div class="stat-title">Participants</div><div class="stat-value"><%= role === 'hr' ? 'Interviewer + Candidate' : 'Interviewer + You' %></div></div>
        <div class="stat"><div class="stat-title">Next session</div><div class="stat-value">2:00 PM today</div></div>
      </div>
    </div>
  </div>

  <div class="card sidebar" id="page-room">
    <div class="room-top">
      <div>
        <div class="room-title" id="room-title">Faculty Interview — Fall 2026</div>
        <div class="room-badge" id="room-status">Live interview</div>
      </div>
      <div class="room-badge" id="room-timer">00:00</div>
    </div>

    <div class="video-grid">
      <div class="video-panel">
        <div class="video-preview" id="jitsiContainer" style="min-height:380px;"></div>
        <div class="video-meta"><span id="jitsiStatus">Jitsi meeting room</span><span class="room-badge">JITSI</span></div>
      </div>
      <div class="video-panel">
        <div class="video-preview" id="localPreview">
          <video id="localVideo" autoplay muted playsinline></video>
          <div id="localPlaceholder" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;background:rgba(15,23,42,0.85);color:var(--muted);font-size:1.1rem;">Camera off</div>
        </div>
        <div class="video-meta"><span id="localNameDisplay"><%= user.name %></span><span id="localBadge">YOU</span></div>
      </div>
    </div>

    <div class="controls">
      <button class="control-btn" id="micBtn" onclick="toggleMic()">🎤 Microphone</button>
      <button class="control-btn" id="camBtn" onclick="toggleCamera()">📹 Camera</button>
      <button class="control-btn" id="screenBtn" onclick="toggleScreenShare()">🖥️ Share</button>
      <button class="control-btn" id="recordBtn" onclick="toggleRecording()">🔴 Record</button>
      <button class="control-btn" onclick="leaveRoom()">🚪 Leave</button>
    </div>

    <div class="sidebar-tabs">
      <div class="tab active" onclick="switchPanel('chat')" id="tab-chat">Chat</div>
      <div class="tab" onclick="switchPanel('notes')" id="tab-notes"><%= role === 'hr' ? 'Evaluation' : 'Notes' %></div>
      <div class="tab" onclick="switchPanel('info')" id="tab-info">Info</div>
    </div>
    <div class="panel active" id="panel-chat">
      <div class="chat-messages" id="chatMessages">
        <div class="msg"><div class="msg-header"><span class="msg-sender">System</span><span>now</span></div><div class="msg-bubble">Welcome to the live interview room. Use chat to communicate.</div></div>
      </div>
      <div class="chat-input-area">
        <textarea class="chat-input" id="chatInput" placeholder="Type a message…" rows="2" onkeydown="handleChatKey(event)"></textarea>
        <button class="send-btn" onclick="sendChat()">➤</button>
      </div>
    </div>
    <div class="panel" id="panel-notes">
      <div class="notes-section">
        <textarea id="notesArea" placeholder="Keep candidate notes here..."></textarea>
        <button class="btn" onclick="showToast('Notes saved locally for this session')">Save Notes</button>
      </div>
    </div>
    <div class="panel" id="panel-info">
      <div class="info-block"><strong>Meeting link:</strong> <a id="meetingLink" href="https://meet.jit.si/JobFaculty-IVW-2026-7834" target="_blank" rel="noreferrer">https://meet.jit.si/JobFaculty-IVW-2026-7834</a></div>
      <div class="info-block"><strong>Meeting code:</strong> IVW-2026-7834</div>
      <div class="info-block"><strong>Role:</strong> <%= role === 'hr' ? 'HR interviewer' : 'Candidate' %></div>
      <div class="info-block"><strong>Session:</strong> Faculty Interview — Fall 2026</div>
      <div class="info-block"><strong>Support:</strong> Use the meeting controls to manage audio, camera, screen share, chat, and recording.</div>
    </div>
  </div>
</div>
<div id="toast" class="toast"></div>
<script src="https://meet.jit.si/external_api.js"></script>
<script>
const scheduledMeetings = <%- JSON.stringify(meetings || []) %>;
let activeMeetingId = scheduledMeetings.length ? String(scheduledMeetings[0].id) : '';
let activeMeetingLink = scheduledMeetings.length ? scheduledMeetings[0].meeting_link || '' : '';
let localStream=null; let micOn=true; let camOn=true; let screenSharing=false; let recording=false; let timerInterval=null; let seconds=0; let jitsiApi=null; const meetingCode='IVW-2026-7834'; const jitsiRoomName='JobFaculty-'+meetingCode;
function navigateTo(page){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.getElementById('page-'+page).classList.add('active'); if(page==='room') startTimer();}
function switchPanel(name){document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));document.getElementById('panel-'+name).classList.add('active');document.getElementById('tab-'+name).classList.add('active');}
function hostMeeting(){
  if (activeMeetingLink) {
    window.open(activeMeetingLink, '_blank');
    return;
  }
  const name=document.getElementById('participantName').value.trim()||'<%= user.name %>';
  const pos=document.getElementById('sessionPosition').value.trim()||'Faculty Interview';
  enterRoom(name,'interviewer',pos);
}
function joinMeeting(){
  if (activeMeetingLink) {
    window.open(activeMeetingLink, '_blank');
    return;
  }
  if (activeMeetingId) {
    window.open(`/meeting/${activeMeetingId}`, '_blank');
    return;
  }
  const name=document.getElementById('participantName').value.trim()||'<%= user.name %>';
  const pos=document.getElementById('sessionPosition').value.trim()||'Faculty Interview';
  enterRoom(name,'candidate',pos);
}
function openScheduledMeeting(meetingId, meetingLink) {
  if (meetingLink) {
    activeMeetingId = meetingId;
    activeMeetingLink = meetingLink;
    window.open(meetingLink, '_blank');
    return;
  }
  if (meetingId) {
    activeMeetingId = meetingId;
    window.open(`/meeting/${meetingId}`, '_blank');
  }
}
function copyInviteLink(meetingLink) {
  const linkToCopy = meetingLink || activeMeetingLink || (activeMeetingId ? `${window.location.origin}/meeting/${activeMeetingId}` : 'https://meet.jit.si/'+jitsiRoomName);
  navigator.clipboard.writeText(linkToCopy).catch(()=>{});
  showToast('Meeting link copied');
}
function enterRoom(name, role, position){navigateTo('room'); document.getElementById('room-title').textContent=position; document.getElementById('localNameDisplay').textContent=name; document.getElementById('localBadge').textContent=role==='interviewer'?'INTERVIEWER':'CANDIDATE'; if(role==='candidate'){document.getElementById('remoteName').textContent='Interviewer';} else {const candidateName=document.getElementById('candidateNameInput')?document.getElementById('candidateNameInput').value.trim()||'Candidate':'Candidate';document.getElementById('remoteName').textContent=candidateName;} document.getElementById('remotePlaceholder').style.display='flex'; document.getElementById('remoteCanvas').style.display='none'; showToast('Entering live interview room'); initCamera(); initJitsi(name);}
function simulateRemoteArrival(){document.getElementById('remotePlaceholder').style.display='none'; document.getElementById('remoteCanvas').style.display='block'; const canvas=document.getElementById('remoteCanvas'); const ctx=canvas.getContext('2d'); let hue=160; const draw=()=>{hue=(hue+0.4)%360; const grad=ctx.createLinearGradient(0,0,640,360); grad.addColorStop(0,`hsl(${hue},30%,20%)`); grad.addColorStop(1,`hsl(${hue+50},25%,12%)`); ctx.fillStyle=grad; ctx.fillRect(0,0,640,360); ctx.fillStyle='rgba(255,255,255,0.12)'; ctx.fillRect(60,80,520,200); ctx.fillStyle='#fff'; ctx.font='bold 30px var(--font-head)'; ctx.fillText('Live candidate feed',80,175); requestAnimationFrame(draw);}; draw();}
async function initCamera(){try{localStream=await navigator.mediaDevices.getUserMedia({video:true,audio:true}); const video=document.getElementById('localVideo'); video.srcObject=localStream; document.getElementById('localPlaceholder').style.display='none'; camOn=true; } catch(e){document.getElementById('localPlaceholder').style.display='flex'; showToast('Camera unavailable — using avatar fallback');}}
function toggleMic(){micOn=!micOn; if(jitsiApi){jitsiApi.executeCommand('toggleAudio');} if(localStream) localStream.getAudioTracks().forEach(t=>t.enabled=micOn); const btn=document.getElementById('micBtn'); btn.classList.toggle('off',!micOn); btn.textContent=micOn?'🎤 Microphone':'🔇 Muted'; showToast(micOn?'Microphone on':'Microphone muted');}
function toggleCamera(){camOn=!camOn; if(jitsiApi){jitsiApi.executeCommand('toggleVideo');} if(localStream) localStream.getVideoTracks().forEach(t=>t.enabled=camOn); document.getElementById('localVideo').style.display=camOn?'block':'none'; document.getElementById('localPlaceholder').style.display=camOn?'none':'flex'; const btn=document.getElementById('camBtn'); btn.classList.toggle('off',!camOn); btn.textContent=camOn?'📹 Camera':'📷 Camera off'; showToast(camOn?'Camera on':'Camera off');}
async function toggleScreenShare(){if(jitsiApi){try{jitsiApi.executeCommand('toggleShareScreen'); screenSharing=!screenSharing; document.getElementById('screenBtn').classList.toggle('off',screenSharing); showToast(screenSharing?'Screen sharing started':'Screen sharing stopped'); return;}catch(e){showToast('Screen share unavailable');}} if(!screenSharing){try{const ss=await navigator.mediaDevices.getDisplayMedia({video:true}); document.getElementById('localVideo').srcObject=ss; screenSharing=true; document.getElementById('screenBtn').classList.add('off'); showToast('Screen sharing started'); ss.getVideoTracks()[0].onended=stopScreenShare;}catch(e){showToast('Screen share cancelled');}}else stopScreenShare();}
function stopScreenShare(){screenSharing=false; document.getElementById('screenBtn').classList.remove('off'); if(localStream) document.getElementById('localVideo').srcObject=localStream; showToast('Screen sharing stopped');}
function toggleRecording(){recording=!recording; const btn=document.getElementById('recordBtn'); btn.classList.toggle('off',!recording); btn.textContent=recording?'⏹ Stop':'🔴 Record'; if(jitsiApi){try{jitsiApi.executeCommand('toggleRecording'); showToast(recording?'Recording started':'Recording stopped'); return;}catch(e){showToast('Recording feature may not be available on this Jitsi instance');}} else {showToast(recording?'Recording started':'Recording stopped');}}
function leaveRoom(){if(confirm('Leave the interview room?')){if(localStream){localStream.getTracks().forEach(t=>t.stop());} if(jitsiApi){jitsiApi.dispose(); jitsiApi=null;} clearInterval(timerInterval); navigateTo('lobby'); showToast('Left the interview room');}}
function handleChatKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat();}}
function sendChat(){const input=document.getElementById('chatInput'); const text=input.value.trim(); if(!text) return; input.value=''; const container=document.getElementById('chatMessages'); const div=document.createElement('div'); div.className='msg mine'; div.innerHTML=`<div class="msg-header"><span>now</span><span class="msg-sender">You</span></div><div class="msg-bubble">${escHtml(text)}</div>`; container.appendChild(div); container.scrollTop=container.scrollHeight; setTimeout(()=>simulateReply(container),1400);} 
function simulateReply(container){const replies=['Great question, let me clarify that further.','Can you walk me through your experience with this topic?','How would you handle a deadline under pressure?','That sounds solid — tell me more about your last project.']; const div=document.createElement('div'); div.className='msg'; div.innerHTML=`<div class="msg-header"><span class="msg-sender">Interviewer</span><span>now</span></div><div class="msg-bubble">${replies[Math.floor(Math.random()*replies.length)]}</div>`; container.appendChild(div); container.scrollTop=container.scrollHeight;}
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function copyInvite(){const inviteLink = activeMeetingLink || (activeMeetingId ? `${window.location.origin}/meeting/${activeMeetingId}` : 'https://meet.jit.si/'+jitsiRoomName); navigator.clipboard.writeText(inviteLink).catch(()=>{}); showToast('Meeting link copied');}
function startTimer(){clearInterval(timerInterval); seconds=0; timerInterval=setInterval(()=>{seconds++; const m=String(Math.floor(seconds/60)).padStart(2,'0'); const s=String(seconds%60).padStart(2,'0'); document.getElementById('room-timer').textContent=`${m}:${s}`;},1000);}
let toastTimer=null; function showToast(msg){const t=document.getElementById('toast'); t.textContent=msg; t.style.opacity='1'; clearTimeout(toastTimer); toastTimer=setTimeout(()=>{t.style.opacity='0';},2600);} 
(function init(){navigateTo('lobby');})();
</script>
</body>
