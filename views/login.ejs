<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login - AcademiaPro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="/styles.css" rel="stylesheet">
<style>
.login-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1a2332 50%, #2563eb 100%);
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  position: relative;
  overflow: hidden;
}

.login-hero::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(30, 64, 175, 0.15), transparent);
  border-radius: 50%;
  pointer-events: none;
}

.login-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  max-width: 1200px;
  width: 100%;
  position: relative;
  z-index: 1;
}

.login-info {
  color: white;
}

.login-info h1 {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  color: white;
}

.login-info p {
  color: rgba(255,255,255,0.9);
  font-size: 1.1rem;
  margin-bottom: 2rem;
  line-height: 1.8;
}

.features {
  list-style: none;
  margin-bottom: 2rem;
}

.features li {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
  color: rgba(255,255,255,0.85);
}

.features i {
  color: #2563eb;
  font-size: 1.3rem;
  min-width: 30px;
}

.form {
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  box-shadow: var(--shadow-xl);
  border-top: 4px solid #2563eb;
}

.form h2 {
  text-align: center;
  margin-bottom: 1.5rem;
  color: #0f172a;
}

.form-group {
  margin-bottom: 1.5rem;
}

.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 0.5rem;
  color: #1e293b;
}

.form-group input {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  font-family: inherit;
  font-size: 0.95rem;
  transition: var(--transition);
}

.form-group input:focus {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.form-group button {
  width: 100%;
  padding: 0.75rem;
  background: linear-gradient(135deg, #2563eb, #1e40af);
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-size: 1rem;
  box-shadow: var(--shadow-md);
}

.form-group button:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn-google {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0.75rem;
  background: #4285f4;
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  font-size: 1rem;
  text-decoration: none;
  box-shadow: var(--shadow-md);
}

.btn-google:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn-google i {
  margin-right: 0.75rem;
}

.alert {
  border-radius: 10px;
  padding: 1rem 1rem;
  margin-bottom: 1.25rem;
  font-size: 0.95rem;
}

.alert-error {
  background: #fee2e2;
  color: #b91c1c;
  border: 1px solid #fecaca;
}

.alert-info {
  background: #e0f2fe;
  color: #0369a1;
  border: 1px solid #bae6fd;
}

.remember-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1rem;
}

.remember-row label {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: #475569;
  font-size: 0.95rem;
}

.remember-row label {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: #475569;
  font-size: 0.95rem;
}

.form p {
  text-align: center;
  margin-top: 1.5rem;
  color: #64748b;
}

@media (max-width: 768px) {
}

@media (max-width: 768px) {
  nav {
    display: none;
  }
  
  .login-content {
    grid-template-columns: 1fr;
  }
  
  .login-info {
    display: none;
  }
  
  .form {
    max-width: 100%;
    width: 100%;
  }
}
</style>
</head>
<body>
<div class="login-hero">
  <div class="login-content">
    <div class="login-info">
      <h1>Welcome to AcademiaPro</h1>
      <p>Find your perfect faculty or professor position with our advanced job portal.</p>
      <ul class="features">
        <li><i class="fas fa-check-circle"></i> Browse top university positions</li>
        <li><i class="fas fa-check-circle"></i> AI-powered interviews</li>
        <li><i class="fas fa-check-circle"></i> Compare job offers</li>
        <li><i class="fas fa-check-circle"></i> Expert matching algorithm</li>
      </ul>
    </div>
    
    <div class="form">
      <h2><i class="fas fa-sign-in-alt"></i> Login</h2>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (info) { %>
        <div class="alert alert-info"><%= info %></div>
      <% } %>
      <form action="/login" method="POST">
        <div class="form-group">
          <label for="email"><i class="fas fa-envelope"></i> Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email" autofocus>
        </div>
        <div class="form-group">
          <label for="password"><i class="fas fa-lock"></i> Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
        </div>
        <div class="form-group remember-row" style="margin-bottom: 0;">
          <label><input type="checkbox" name="remember"> Remember me</label>
          <label><input type="checkbox" id="showPassword"> Show password</label>
        </div>
        <div class="form-group">
          <button type="submit"><i class="fas fa-sign-in-alt"></i> Login</button>
        </div>
      </form>
      <div class="form-group">
        <button id="firebaseGoogleBtn" type="button" class="btn btn-google"><i class="fab fa-google"></i> Sign in with Google</button>
      </div>
      <p>Don't have an account? <a href="/register"><i class="fas fa-arrow-right"></i> Register now</a></p>
      <p>Forgot your password? <a href="/reset"><i class="fas fa-key"></i> Reset it here</a></p>
      <p>HR user? <a href="/hr-login"><i class="fas fa-arrow-right"></i> Login here</a></p>
    </div>
  </div>
</div>
</body>
<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/9.22.2/firebase-app.js';
  import { getAuth, GoogleAuthProvider, signInWithPopup } from 'https://www.gstatic.com/firebasejs/9.22.2/firebase-auth.js';

  const firebaseConfig = {
    apiKey: 'AIzaSyB_PLqF1qcEEhnrYaUA1k5Tsi61MW0xZS8',
    authDomain: 'job-faculty.firebaseapp.com',
    projectId: 'job-faculty',
    storageBucket: 'job-faculty.firebasestorage.app',
    messagingSenderId: '62016617558',
    appId: '1:62016617558:web:014890807abc948a928ff7',
    measurementId: 'G-EM3X896YYN'
  };

  const alternateFirebaseApiKey = 'AIzaSyBF8PsHnsoy4tfOH5URzp1ipTnH_bj08TE'; // Alternate auth key

  const app = initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const provider = new GoogleAuthProvider();

  document.getElementById('firebaseGoogleBtn').addEventListener('click', async () => {
    try {
      const result = await signInWithPopup(auth, provider);
      const idToken = await result.user.getIdToken();
      const response = await fetch('/auth/google-firebase', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken })
      });
      if (response.ok) {
        const data = await response.json();
        window.location.href = data.redirect || '/dashboard';
      } else {
        const errorText = await response.text();
        alert('Google sign-in failed: ' + errorText);
      }
    } catch (error) {
      console.error('Firebase Google sign-in error:', error);
      alert('Google sign-in failed. Please try again.');
    }
  });

  document.getElementById('showPassword')?.addEventListener('change', (event) => {
    const passwordField = document.getElementById('password');
    if (passwordField) {
      passwordField.type = event.target.checked ? 'text' : 'password';
    }
  });
</script>
</html>